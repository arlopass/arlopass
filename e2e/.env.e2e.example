# ─── BYOM AI E2E Test Environment ───
# Copy this file to .env.e2e and fill in credentials for provider tests.
# Tests tagged @cloud-credentials will be skipped if the relevant vars are empty.
# NEVER commit the .env.e2e file — it is gitignored.

# ─── Per-Provider Enable Flags ───
# Set to "true" to enable E2E tests for a specific provider.
# When a flag is missing or set to anything other than "true",
# the corresponding provider tests are skipped.
# This lets you run only the providers you care about.
TEST_ANTHROPIC_ENABLED=false
TEST_OPENAI_ENABLED=false
TEST_GEMINI_ENABLED=false
TEST_PERPLEXITY_ENABLED=false
TEST_BEDROCK_ENABLED=false
TEST_VERTEX_ENABLED=false
TEST_FOUNDRY_ENABLED=false
TEST_OLLAMA_ENABLED=false

# ─── Live Integration Flag ───
# Set to "true" to enable real end-to-end integration tests that use
# the actual extension transport + running bridge + a real provider.
# Requires the bridge to be running and at least one provider configured
# in the extension with TEST_*_ENABLED=true and valid credentials.
# When false (default), integration tests use mock transport only.
TEST_LIVE_INTEGRATION_ENABLED=false

# ─── Anthropic ───
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── OpenAI ───
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_DEFAULT_MODEL=

# ─── Google Gemini ───
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_PROJECT_ID=

# ─── Perplexity ───
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_DEFAULT_MODEL=

# ─── Amazon Bedrock ───
BEDROCK_REGION=
BEDROCK_MODEL_ACCESS_POLICY=
BEDROCK_API_KEY=
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_SESSION_TOKEN=
BEDROCK_ROLE_ARN=
BEDROCK_EXTERNAL_ID=
BEDROCK_TENANT_ID=

# ─── Google Vertex AI ───
VERTEX_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_SERVICE_ACCOUNT_JSON=

# ─── Microsoft Foundry ───
FOUNDRY_API_URL=
FOUNDRY_API_VERSION=
FOUNDRY_DEPLOYMENT=
FOUNDRY_API_KEY=

# ─── Ollama (local) ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── Bridge ───
BRIDGE_HOST_NAME=com.byom.bridge
