---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/ui/PageHero.astro";
import Divider from "../components/Divider.astro";

const pageTitle =
  "Roadmap — Arlopass | What We're Building Next for AI Access Management";
const pageDesc =
  "See what's coming next for Arlopass — the open-source browser extension and SDK for AI access management. Transparent roadmap updated regularly.";

interface RoadmapItem {
  title: string;
  description: string;
  tag?: string;
}

const now: RoadmapItem[] = [
  {
    title: "Extension v1 — redesigned UI/UX",
    description:
      "A ground-up redesign of the extension popup and options page for a cleaner, faster, more intuitive experience. Improved provider management, connection flow, and settings.",
    tag: "Extension",
  },
  {
    title: "Vercel AI SDK adapter",
    description:
      "Drop-in Arlopass transport for the Vercel AI SDK — use useChat and streamText with any user-provided model.",
    tag: "Developer",
  },
  {
    title: "Safari extension",
    description:
      "Native Safari Web Extension using the same core with WebKit-specific adaptations. Bringing Arlopass to every major browser.",
    tag: "Extension",
  },
  {
    title: "React UI component library",
    description:
      "Pre-built, styled React components — chat bubbles, model pickers, provider status — for rapid integration.",
    tag: "Developer",
  },
];

const next: RoadmapItem[] = [
  {
    title: "MCP tool integration",
    description:
      "Support for Model Context Protocol tools, allowing web apps to expose tools and resources to AI models via the Arlopass bridge.",
    tag: "Developer",
  },
  {
    title: "Image and multimodal support",
    description:
      "First-class support for image inputs and multimodal models across all adapters.",
    tag: "Developer",
  },
  {
    title: "Provider health monitoring",
    description:
      "Real-time provider latency and availability monitoring visible in the extension popup.",
    tag: "Extension",
  },
  {
    title: "Conversation history",
    description:
      "Persistent conversation history across sessions, stored locally in the vault. Search, bookmark, and resume past chats.",
    tag: "Extension",
  },
  {
    title: "LangChain / LlamaIndex adapters",
    description:
      "Arlopass transport adapters for LangChain.js and LlamaIndex.TS — bring user-provided models to any agentic framework.",
    tag: "Developer",
  },
  {
    title: "ISO 27001 & SOC 2 certification",
    description:
      "Completing our ISO 27001 ISMS and SOC 2 Type II observation period with external auditors.",
    tag: "Compliance",
  },
];

const later: RoadmapItem[] = [
  {
    title: "AI cost tracking",
    description:
      "Per-app, per-model cost estimation and budgeting with usage alerts visible in the extension.",
    tag: "Extension",
  },
  {
    title: "Plugin marketplace",
    description:
      "Community-built adapters, policy templates, and UI themes — discoverable and installable from a marketplace.",
    tag: "Ecosystem",
  },
  {
    title: "Mobile companion app",
    description:
      "iOS and Android app for managing provider connections and viewing AI activity on mobile.",
    tag: "Extension",
  },
  {
    title: "Enterprise admin dashboard",
    description:
      "Centralized dashboard for IT teams to manage policy bundles, view audit logs, and monitor AI usage across the organization.",
    tag: "Enterprise",
  },
];

function tagColor(tag: string): string {
  switch (tag) {
    case "Extension":
      return "bg-[var(--ap-brand-subtle)] text-brand";
    case "Developer":
      return "bg-[var(--ap-success-subtle)] text-success";
    case "Compliance":
      return "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-secondary)]";
    case "Enterprise":
      return "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-tertiary)]";
    case "Ecosystem":
      return "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-secondary)]";
    default:
      return "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-secondary)]";
  }
}
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl="https://arlopass.com/roadmap"
>
  <Nav />
  <main>
    <PageHero
      label="Roadmap"
      title="What we're building"
      description="A transparent look at what's in progress, what's coming next, and where we're heading. This roadmap is updated regularly and reflects our current priorities."
    />

    {/* ── Now ──────────────────────────────────────────────── */}
    <section class="bg-[var(--ap-bg-surface)]" id="now">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >In progress</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          What we're working on now
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
        >
          Active development — these are our current priorities.
        </p>
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 border border-[var(--ap-border)]"
      >
        {
          now.map((item, i) => (
            <div
              class={`bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10 ${i % 2 === 0 ? "sm:border-r border-[var(--ap-border)]" : ""} ${i < now.length - 2 || (now.length % 2 !== 0 && i < now.length - 1) ? "border-b border-[var(--ap-border)]" : ""}`}
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-success shrink-0" />
                {item.tag && (
                  <span
                    class={`text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded ${tagColor(item.tag)}`}
                  >
                    {item.tag}
                  </span>
                )}
              </div>
              <h3 class="text-base font-semibold text-[var(--ap-text-primary)] mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <Divider />

    {/* ── Next ─────────────────────────────────────────────── */}
    <section id="next">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >Up next</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          Coming soon
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
        >
          Next in the pipeline — scoped, designed, and waiting for bandwidth.
        </p>
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-[var(--ap-border)] [&>*]:border-b [&>*]:border-[var(--ap-border)] [&>*]:sm:border-r [&>*:nth-child(2n)]:sm:border-r-0 [&>*]:lg:border-r [&>*:nth-child(3n)]:lg:border-r-0 [&>*:nth-child(2n)]:lg:border-r [&>*:last-child]:border-b-0 [&>*:nth-last-child(-n+3)]:lg:border-b-0 [&>*:nth-last-child(-n+2)]:sm:border-b-0 [&>*:nth-last-child(-n+2)]:lg:border-b [&>*:nth-last-child(-n+3)]:lg:border-b-0"
      >
        {
          next.map((item) => (
            <div class="bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-amber-500 shrink-0" />
                {item.tag && (
                  <span
                    class={`text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded ${tagColor(item.tag)}`}
                  >
                    {item.tag}
                  </span>
                )}
              </div>
              <h3 class="text-base font-semibold text-[var(--ap-text-primary)] mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <Divider />

    {/* ── Later ────────────────────────────────────────────── */}
    <section class="bg-[var(--ap-bg-surface)]" id="later">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >Exploring</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          On the horizon
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
        >
          Ideas we're excited about — not yet committed, but actively exploring.
        </p>
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 border border-[var(--ap-border)]"
      >
        {
          later.map((item, i) => (
            <div
              class={`bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10 ${i % 2 === 0 ? "sm:border-r border-[var(--ap-border)]" : ""} ${i < later.length - 2 || (later.length % 2 !== 0 && i < later.length - 1) ? "border-b border-[var(--ap-border)]" : ""}`}
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-[var(--ap-text-tertiary)] shrink-0" />
                {item.tag && (
                  <span
                    class={`text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded ${tagColor(item.tag)}`}
                  >
                    {item.tag}
                  </span>
                )}
              </div>
              <h3 class="text-base font-semibold text-[var(--ap-text-primary)] mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    {/* ── CTA ──────────────────────────────────────────────── */}
    <section class="border-t border-[var(--ap-border)]">
      <div class="py-20 md:py-24 px-6 md:px-10 text-center">
        <span
          class="block text-sm font-pixel tracking-[0.08em] text-brand mb-3"
        >
          Have an idea?
        </span>
        <h2
          class="text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-tight text-[var(--ap-text-primary)] mb-3"
        >
          Shape what we build next
        </h2>
        <p
          class="text-sm text-[var(--ap-text-secondary)] max-w-md mx-auto mb-8"
        >
          Arlopass is open source. File a feature request, vote on existing
          ideas, or contribute directly.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="https://github.com/arlopass/arlopass/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-cta-text)] bg-[var(--ap-cta-bg)] py-2.5 px-6 rounded-lg no-underline hover:opacity-90 transition-opacity"
          >
            Request a feature
          </a>
          <a
            href="https://discord.gg/HwNA78mqUy"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-text-primary)] bg-transparent border border-[var(--ap-border-strong)] py-2.5 px-6 rounded-lg no-underline hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] transition-all"
          >
            Join Discord
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
