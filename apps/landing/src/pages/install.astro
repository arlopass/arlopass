---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/ui/PageHero.astro";
import CopyCommand from "../components/ui/CopyCommand.astro";
import Divider from "../components/Divider.astro";
import BridgeDownloads from "../components/islands/BridgeDownloads.tsx";

const pageTitle =
  "Install Arlopass — Browser Extension & Bridge for AI Access Management";
const pageDesc =
  "Install the Arlopass browser extension for Chrome, Edge, or Firefox and download the native bridge for macOS, Linux, or Windows. Free, open source, under 60 seconds.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Arlopass",
  applicationCategory: "BrowserApplication",
  operatingSystem: "Windows, macOS, Linux",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  downloadUrl: "https://chrome.google.com/webstore",
  softwareVersion: "1.0",
  description: pageDesc,
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to install Arlopass",
  description:
    "Install the Arlopass browser extension and native bridge in under 60 seconds.",
  totalTime: "PT1M",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Install the browser extension",
      text: "Add Arlopass from the Chrome Web Store, Edge Add-ons, or Firefox Add-ons.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Install the native bridge",
      text: "Run the one-line installer for your OS or download the binary directly.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Connect your providers",
      text: "Open the extension, add your AI provider API keys, and start using AI on your terms.",
    },
  ],
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl="https://arlopass.com/install"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  <Nav />
  <main>
    <PageHero
      label="Get started"
      title="Install Arlopass"
      description="Two components, under 60 seconds. Install the browser extension to manage AI access, then add the native bridge for local models and advanced features."
    />

    {/* ── Extension detected banner ──────────────────────── */}
    <div id="ext-detected" class="hidden border-b border-[var(--ap-border)]">
      <div class="flex items-center gap-4 px-4 md:px-6 lg:px-8 py-5">
        <span
          class="flex items-center justify-center w-8 h-8 rounded-full bg-[var(--ap-bg-surface)] border border-[var(--ap-border)]"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-success"
            ><polyline points="20 6 9 17 4 12"></polyline></svg
          >
        </span>
        <div>
          <span class="text-sm font-medium text-[var(--ap-text-primary)]"
            >Extension installed</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)] block mt-0.5">
            You're all set. <a
              href="#bridge"
              class="text-brand no-underline hover:text-[var(--ap-text-link-hover)] transition-colors"
              >Skip to the native bridge →</a
            >
          </span>
        </div>
      </div>
    </div>

    {/* ── Step 1: Browser Extension ────────────────────────── */}
    <section class="bg-[var(--ap-bg-surface)]" id="extension">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >Step 1</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          Browser extension
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
          id="ext-description"
        >
          The extension lives in your browser and manages connections between
          web apps and your AI providers. Install it from your browser's
          official store.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 border border-[var(--ap-border)]"
      >
        {/* Chrome */}
        <div
          class="flex flex-col border-b md:border-b-0 md:border-r border-[var(--ap-border)] bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <div class="flex items-center gap-3 mb-4">
            <img
              src="/img/chrome.svg"
              alt=""
              width="32"
              height="32"
              aria-hidden="true"
            />
            <span class="text-base font-semibold text-[var(--ap-text-primary)]"
              >Google Chrome</span
            >
          </div>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-6 flex-1"
          >
            Install from the Chrome Web Store. Works with Chrome, Brave, Arc,
            and all Chromium-based browsers.
          </p>
          <button
            data-store-coming-soon
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-cta-text)] bg-[var(--ap-cta-bg)] py-2.5 px-5 rounded-lg border-none cursor-pointer hover:opacity-85 transition-opacity"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"
              ></path><polyline points="7 10 12 15 17 10"></polyline><line
                x1="12"
                y1="15"
                x2="12"
                y2="3"></line></svg
            >
            Add to Chrome
          </button>
        </div>

        {/* Edge */}
        <div
          class="flex flex-col border-b md:border-b-0 md:border-r border-[var(--ap-border)] bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <div class="flex items-center gap-3 mb-4">
            <img
              src="/img/edge.svg"
              alt=""
              width="32"
              height="32"
              aria-hidden="true"
            />
            <span class="text-base font-semibold text-[var(--ap-text-primary)]"
              >Microsoft Edge</span
            >
          </div>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-6 flex-1"
          >
            Install from the Edge Add-ons store. Full compatibility with the
            Chromium extension API.
          </p>
          <button
            data-store-coming-soon
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-text-primary)] bg-transparent border border-[var(--ap-border-strong)] py-2.5 px-5 rounded-lg cursor-pointer hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] transition-all"
          >
            Add to Edge
          </button>
        </div>

        {/* Firefox */}
        <div
          class="flex flex-col bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <div class="flex items-center gap-3 mb-4">
            <img
              src="/img/firefox.svg"
              alt=""
              width="32"
              height="32"
              aria-hidden="true"
            />
            <span class="text-base font-semibold text-[var(--ap-text-primary)]"
              >Firefox</span
            >
          </div>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-6 flex-1"
          >
            Install from Firefox Add-ons. Uses the WebExtension API with native
            messaging support.
          </p>
          <button
            data-store-coming-soon
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-text-primary)] bg-transparent border border-[var(--ap-border-strong)] py-2.5 px-5 rounded-lg cursor-pointer hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] transition-all"
          >
            Add to Firefox
          </button>
        </div>
      </div>
    </section>

    <Divider />

    {/* ── Step 2: Native Bridge ────────────────────────────── */}
    <section id="bridge">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >Step 2</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          Native bridge
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
        >
          The bridge runs on your machine and securely routes requests between
          the extension and your AI providers. It enables local model support
          (Ollama), HMAC authentication, and enterprise policy enforcement.
        </p>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 border border-[var(--ap-border)]"
      >
        {/* Left — download options */}
        <div
          class="bg-[var(--ap-bg-card)] border-b lg:border-b-0 lg:border-r border-[var(--ap-border)]"
        >
          <BridgeDownloads client:load />
        </div>

        {/* Right — mosaic background + SmartScreen preview */}
        <div class="relative min-h-[420px] lg:min-h-0 overflow-hidden">
          <canvas
            data-mosaic-src="/img/bg5.webp"
            class="absolute inset-0 w-full h-full"></canvas>
          <div class="absolute inset-0 bg-[var(--ap-mosaic-overlay)]"></div>
          <div
            class="relative z-10 flex flex-col items-center justify-center h-full p-8 lg:p-12 gap-6"
          >
            <div
              class="w-full max-w-[360px] w-fit rounded-2xl bg-[var(--ap-glass-bg)] p-1 shadow-2xl ring shadow-black/80 ring-[var(--ap-glass-ring)] backdrop-blur-lg overflow-hidden"
            >
              <div
                class="rounded-xl bg-[var(--ap-bg-base)] w-fit overflow-hidden"
              >
                {/* Replace src with your SmartScreen walkthrough GIF */}
                <img
                  src="/img/smartscreen-walkthrough.gif"
                  alt="Windows SmartScreen walkthrough: click 'More info' then 'Run anyway'"
                  class="w-full h-auto block max-w-[360px]"
                  loading="lazy"
                />
              </div>
            </div>
            <p
              class="text-xs text-center leading-relaxed max-w-[360px] rounded-lg px-4 py-3 bg-[var(--ap-bg-base)]/80 backdrop-blur-sm"
              style="color: var(--ap-text-secondary)"
            >
              The bridge isn't code-signed yet. After downloading on Windows,
              follow the steps above to whitelist Arlopass.
            </p>
          </div>
        </div>
      </div>

      <Divider />
      <div class="grid grid-cols-1 lg:grid-cols-2">
        {/* macOS / Linux */}
        <div
          class="border-b lg:border-b-0 lg:border-r border-[var(--ap-border)] bg-[var(--ap-bg-card)] p-8 sm:p-10"
        >
          <span class="text-sm font-pixel tracking-[0.08em] text-brand"
            >macOS & Linux</span
          >
          <h3
            class="mt-2 text-lg font-semibold tracking-tight text-[var(--ap-text-primary)] mb-4"
          >
            One‑line installer
          </h3>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-6"
          >
            Downloads the latest release from GitHub, verifies the SHA-256
            checksum, installs to <code class="text-xs">~/.local/bin</code>, and
            registers the native messaging host for Chrome, Edge, and Firefox.
          </p>
          <CopyCommand
            command="curl -fsSL https://arlopass.com/install.sh | sh"
            label="Terminal"
          />
          <div class="mt-4">
            <CopyCommand
              command="curl -fsSL https://arlopass.com/install.sh | sh -s -- --uninstall"
              label="Uninstall"
            />
          </div>
        </div>

        {/* Windows */}
        <div class="bg-[var(--ap-bg-card)] p-8 sm:p-10">
          <span class="text-sm font-pixel tracking-[0.08em] text-brand"
            >Windows</span
          >
          <h3
            class="mt-2 text-lg font-semibold tracking-tight text-[var(--ap-text-primary)] mb-4"
          >
            PowerShell installer
          </h3>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-6"
          >
            Downloads the latest release, verifies SHA-256, installs to <code
              class="text-xs">%LOCALAPPDATA%\Arlopass\bin</code
            >, and sets up native messaging host registry entries.
          </p>
          <CopyCommand
            command="irm https://arlopass.com/install.ps1 | iex"
            label="PowerShell"
          />
          <div class="mt-4">
            <CopyCommand
              command="irm https://arlopass.com/install.ps1 | iex -Uninstall"
              label="Uninstall"
            />
          </div>
        </div>
      </div>
    </section>

    <Divider />

    {/* ── What's next ──────────────────────────────────────── */}
    <section class="bg-[var(--ap-bg-surface)]">
      <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
        <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
          >Next steps</span
        >
        <h2
          class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
        >
          You're all set
        </h2>
        <p
          class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
        >
          Open the Arlopass extension, connect your first AI provider, and start
          using AI on your terms.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 border border-[var(--ap-border)]"
      >
        <div
          class="border-b md:border-b-0 md:border-r border-[var(--ap-border)] bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <span class="text-xs font-semibold text-brand font-mono">01</span>
          <h3
            class="mt-2 text-lg font-semibold text-[var(--ap-text-primary)] mb-2"
          >
            Connect a provider
          </h3>
          <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
            Add your Ollama, Claude, GPT, Gemini, or Bedrock credentials. Keys
            stay in your encrypted vault on this device.
          </p>
        </div>
        <div
          class="border-b md:border-b-0 md:border-r border-[var(--ap-border)] bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <span class="text-xs font-semibold text-brand font-mono">02</span>
          <h3
            class="mt-2 text-lg font-semibold text-[var(--ap-text-primary)] mb-2"
          >
            Visit an Arlopass app
          </h3>
          <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
            When a web app requests AI, you'll see a clear prompt. Pick your
            model, approve, and go.
          </p>
        </div>
        <div
          class="bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10"
        >
          <span class="text-xs font-semibold text-brand font-mono">03</span>
          <h3
            class="mt-2 text-lg font-semibold text-[var(--ap-text-primary)] mb-2"
          >
            Read the quickstart
          </h3>
          <p
            class="text-sm text-[var(--ap-text-secondary)] leading-relaxed mb-4"
          >
            Developers: integrate Arlopass into your app in about 10 lines of
            TypeScript.
          </p>
          <a
            href="/docs/getting-started/quickstart-web-sdk"
            class="text-sm font-medium text-brand no-underline hover:text-[var(--ap-text-link-hover)] transition-colors"
          >
            Read the quickstart →
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    // Detect if the Arlopass extension is installed.
    // The extension's content script injects `window.arlopass` on http(s) pages.
    // We also check for a data attribute the content script may set on <html>.
    function checkExtension() {
      const hasTransport = typeof (window as any).arlopass !== "undefined";
      const hasAttr = document.documentElement.hasAttribute("data-arlopass");
      return hasTransport || hasAttr;
    }

    function showDetected() {
      const banner = document.getElementById("ext-detected");
      if (banner) banner.classList.remove("hidden");
    }

    // Check immediately
    if (checkExtension()) {
      showDetected();
    } else {
      // The content script may inject slightly after DOMContentLoaded,
      // so re-check after a short delay.
      setTimeout(() => {
        if (checkExtension()) showDetected();
      }, 800);
    }
  </script>

  <script>
    // Mosaic canvas renderer for the bridge download section
    const TILE = 16;
    document
      .querySelectorAll<HTMLCanvasElement>("[data-mosaic-src]")
      .forEach((canvas) => {
        const src = canvas.dataset.mosaicSrc!;
        const ctx = canvas.getContext("2d")!;
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.src = src;
        img.onload = () => {
          const draw = () => {
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            if (!w || !h) return;
            canvas.width = w;
            canvas.height = h;
            const cols = Math.ceil(w / TILE);
            const rows = Math.ceil(h / TILE);
            const imgRatio = img.naturalWidth / img.naturalHeight;
            const canvasRatio = w / h;
            let sx = 0,
              sy = 0,
              sw = img.naturalWidth,
              sh = img.naturalHeight;
            if (imgRatio > canvasRatio) {
              sw = img.naturalHeight * canvasRatio;
              sx = (img.naturalWidth - sw) / 2;
            } else {
              sh = img.naturalWidth / canvasRatio;
              sy = (img.naturalHeight - sh) / 2;
            }
            const off = document.createElement("canvas");
            off.width = cols;
            off.height = rows;
            off
              .getContext("2d")!
              .drawImage(img, sx, sy, sw, sh, 0, 0, cols, rows);
            ctx.imageSmoothingEnabled = false;
            ctx.drawImage(off, 0, 0, cols, rows, 0, 0, w, h);
          };
          draw();
          new ResizeObserver(draw).observe(canvas);
        };
      });
  </script>
</Layout>
