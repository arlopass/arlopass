---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/ui/PageHero.astro";

const pageTitle = "Changelog — Arlopass | What's New in AI Access Management";
const pageDesc =
  "Track every release, feature, and fix in Arlopass — the open-source browser extension and SDK for AI access management. Updated with every release.";

const releases = [
  {
    version: "0.1.0",
    date: "2026-03-15",
    tag: "Initial release",
    changes: [
      { type: "feat", text: "Browser extension with popup and options UI" },
      {
        type: "feat",
        text: "Native bridge with HMAC handshake authentication",
      },
      { type: "feat", text: "Ollama adapter for local model support" },
      { type: "feat", text: "Claude subscription adapter" },
      { type: "feat", text: "OpenAI GPT adapter" },
      { type: "feat", text: "Google Gemini adapter" },
      { type: "feat", text: "Amazon Bedrock adapter" },
      { type: "feat", text: "Google Vertex AI adapter" },
      { type: "feat", text: "Perplexity adapter" },
      { type: "feat", text: "Microsoft Foundry adapter" },
      { type: "feat", text: "Web SDK with 10-line integration" },
      { type: "feat", text: "React SDK with hooks and components" },
      { type: "feat", text: "Per-request user consent flow" },
      { type: "feat", text: "Provider switching without code changes" },
      { type: "feat", text: "Async iterator streaming support" },
      { type: "feat", text: "Enterprise policy bundles (Ed25519 signed)" },
      { type: "feat", text: "JSONL + OTLP audit trail export" },
      {
        type: "feat",
        text: "One-line installers for macOS, Linux, and Windows",
      },
    ],
  },
];

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function typeBadge(type: string): { label: string; cls: string } {
  switch (type) {
    case "feat":
      return {
        label: "New",
        cls: "bg-[var(--ap-success-subtle)] text-success",
      };
    case "fix":
      return { label: "Fix", cls: "bg-[var(--ap-brand-subtle)] text-brand" };
    case "perf":
      return {
        label: "Perf",
        cls: "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-secondary)]",
      };
    case "breaking":
      return {
        label: "Breaking",
        cls: "bg-red-50 text-danger dark:bg-red-950",
      };
    default:
      return {
        label: type,
        cls: "bg-[var(--ap-bg-elevated)] text-[var(--ap-text-secondary)]",
      };
  }
}
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonicalUrl="https://arlopass.com/changelog"
>
  <Nav />
  <main>
    <PageHero
      label="Changelog"
      title="What's new in Arlopass"
      description="Every feature, fix, and improvement — documented with every release. Follow along as we build the future of AI access management."
    />

    {/* ── Release timeline ─────────────────────────────────── */}
    <div class="border-t border-[var(--ap-border)]">
      {
        releases.map((release, ri) => (
          <article
            class={`${ri < releases.length - 1 ? "border-b border-[var(--ap-border)]" : ""}`}
            id={`v${release.version}`}
          >
            <div class="grid grid-cols-1 md:grid-cols-[200px_1fr]">
              {/* Date sidebar */}
              <div class="p-6 sm:p-8 md:border-r border-[var(--ap-border)] bg-[var(--ap-bg-surface)]">
                <span class="block text-lg font-bold text-[var(--ap-text-primary)] font-mono tabular-nums">
                  v{release.version}
                </span>
                <time
                  class="block text-xs text-[var(--ap-text-tertiary)] mt-1"
                  datetime={release.date}
                >
                  {formatDate(release.date)}
                </time>
                {release.tag && (
                  <span class="inline-block mt-2 text-xs font-pixel tracking-[0.05em] text-brand">
                    {release.tag}
                  </span>
                )}
              </div>

              {/* Changes */}
              <div class="p-6 sm:p-8">
                <ul class="flex flex-col gap-3">
                  {release.changes.map((change) => {
                    const badge = typeBadge(change.type);
                    return (
                      <li class="flex items-start gap-3">
                        <span
                          class={`shrink-0 mt-0.5 text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}
                        >
                          {badge.label}
                        </span>
                        <span class="text-sm text-[var(--ap-text-body)] leading-relaxed">
                          {change.text}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    {/* ── Stay updated ─────────────────────────────────────── */}
    <section class="border-t border-[var(--ap-border)]">
      <div class="py-20 md:py-24 px-6 md:px-10 text-center">
        <span
          class="block text-sm font-pixel tracking-[0.08em] text-brand mb-3"
        >
          Stay updated
        </span>
        <h2
          class="text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-tight text-[var(--ap-text-primary)] mb-3"
        >
          Follow releases on GitHub
        </h2>
        <p
          class="text-sm text-[var(--ap-text-secondary)] max-w-md mx-auto mb-8"
        >
          Star the repo and watch for releases to get notified of every update.
        </p>
        <a
          href="https://github.com/arlopass/arlopass/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-cta-text)] bg-[var(--ap-cta-bg)] py-2.5 px-6 rounded-lg no-underline hover:opacity-90 transition-opacity"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            ><path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          View all releases
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
