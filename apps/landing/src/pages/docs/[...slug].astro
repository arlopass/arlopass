---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    // Astro 6 glob loader: entry.id is the file path relative to base dir.
    // Strip .mdx/.md extension if present to get a clean URL slug.
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const slug = entry.id.replace(/\.mdx?$/, '');
---

<DocsLayout frontmatter={entry.data} headings={headings} slug={slug} rawContent={entry.body}>
  <Content />
</DocsLayout>
