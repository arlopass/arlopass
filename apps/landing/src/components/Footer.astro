---
const currentYear = new Date().getFullYear();
const links = {
  product: [
    { label: "Install", href: "/install" },
    { label: "Documentation", href: "/docs" },
    { label: "Quickstart", href: "/docs/getting-started/quickstart-web-sdk" },
    { label: "SDK Reference", href: "/docs/reference/web-sdk/client" },
  ],
  developers: [
    { label: "GitHub", href: "https://github.com/arlopass" },
    { label: "npm Packages", href: "https://www.npmjs.com/org/arlopass" },
    { label: "Discord", href: "https://discord.gg/arlopass" },
    { label: "Changelog", href: "/changelog" },
    { label: "Roadmap", href: "/roadmap" },
  ],
  company: [
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" },
    { label: "Trust Center", href: "/trust-center" },
    {
      label: "Security",
      href: "https://github.com/arlopass/arlopass/security",
    },
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
  ],
};
---

<footer
  class="pt-16 pb-8 border-t border-[var(--ap-border)]"
  role="contentinfo"
>
  <div class="px-4 md:px-6 lg:px-8">
    <div
      class="grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10 md:gap-8 mb-12"
    >
      <div>
        <a
          href="/"
          class="flex items-center gap-2 text-[var(--ap-text-primary)] no-underline text-base font-semibold mb-3"
        >
          <img
            src="/ArlopassIcon.svg"
            alt=""
            width="24"
            height="24"
            aria-hidden="true"
          />
          <span>Arlopass</span>
        </a>
        <p class="text-sm text-[var(--ap-text-tertiary)]">
          Your AI, your models, your rules.
        </p>
      </div>

      {
        Object.entries(links).map(([heading, items]) => (
          <div>
            <h3 class="text-xs font-medium uppercase tracking-widest text-[var(--ap-text-tertiary)] mb-4">
              {heading}
            </h3>
            <ul class="flex flex-col gap-2 list-none">
              {items.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      link.href.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                    class="text-sm text-[var(--ap-text-secondary)] no-underline hover:text-[var(--ap-text-primary)] transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="flex flex-wrap items-center justify-between gap-4 pt-8 border-t border-[var(--ap-border)]"
    >
      <p class="text-xs text-[var(--ap-text-tertiary)]">
        &copy; {currentYear} Arlopass. MIT Licensed. Open source.
      </p>
      <div class="flex gap-4">
        {
          [
            {
              label: "GitHub",
              href: "https://github.com/arlopass",
              icon: `<path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>`,
            },
            {
              label: "X",
              href: "https://x.com/arlopass",
              icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
            },
            {
              label: "Discord",
              href: "https://discord.gg/arlopass",
              icon: `<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>`,
            },
          ].map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[var(--ap-text-tertiary)] hover:text-[var(--ap-text-primary)] transition-colors"
              aria-label={s.label}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                set:html={s.icon}
              />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
