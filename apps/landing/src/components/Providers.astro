---
const ICON_BASE = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";

const providers = [
  { name: "Ollama", slug: "ollama" },
  { name: "Claude", slug: "claude" },
  { name: "OpenAI", slug: "openai" },
  { name: "Gemini", slug: "gemini" },
  { name: "Bedrock", slug: "bedrock" },
  { name: "Perplexity", slug: "perplexity" },
  { name: "LM Studio", slug: "lmstudio" },
  { name: "Mistral", slug: "mistral" },
  { name: "Vertex AI", slug: "vertexai" },
  { name: "Grok", slug: "grok" },
];
---

<section class="py-12" aria-label="Supported AI providers">
  <div class="px-4 md:px-6 lg:px-8">
    <p
      class="text-center text-sm text-[var(--ap-text-tertiary)] mb-6 uppercase tracking-widest font-medium"
    >
      Works with your favorite AI providers
    </p>
    <div class="flex flex-wrap justify-center gap-3 max-[480px]:gap-2">
      {
        providers.map((p) => (
          <div class="flex items-center gap-2 py-2.5 px-[18px] text-sm font-medium text-[var(--ap-text-secondary)] hover:text-[var(--ap-text-body)] hover:scale-102 transition-all max-[480px]:py-2 max-[480px]:px-3 max-[480px]:text-xs">
            <img
              class="w-5 h-5 max-[480px]:w-4 max-[480px]:h-4 shrink-0 provider-icon"
              src={`${ICON_BASE}/${p.slug}.svg`}
              alt=""
              width="20"
              height="20"
              loading="lazy"
            />
            <span>{p.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .provider-icon {
    filter: brightness(0) invert(0.7);
    transition: filter 150ms ease;
  }
  .provider-icon:hover {
    filter: brightness(0) invert(0.9);
  }
  :global([data-theme="light"]) .provider-icon {
    filter: brightness(0) invert(0.3);
  }
  :global([data-theme="light"]) .provider-icon:hover {
    filter: brightness(0) invert(0.1);
  }
</style>
