---
const ICON_BASE = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";

const providers = [
  { name: "Ollama", slug: "ollama" },
  { name: "Claude", slug: "claude" },
  { name: "OpenAI", slug: "openai" },
  { name: "Gemini", slug: "gemini" },
  { name: "Bedrock", slug: "bedrock" },
  { name: "Perplexity", slug: "perplexity" },
  { name: "LM Studio", slug: "lmstudio" },
  { name: "Mistral", slug: "mistral" },
  { name: "Vertex AI", slug: "vertexai" },
  { name: "Grok", slug: "grok" },
];
---

<section class="providers" aria-label="Supported AI providers">
  <div class="container">
    <p class="providers-label">Works with your favorite AI providers</p>
    <div class="providers-track">
      {
        providers.map((p) => (
          <div class="provider-chip">
            <img
              class="provider-icon"
              src={`${ICON_BASE}/${p.slug}.svg`}
              alt=""
              width="20"
              height="20"
              loading="lazy"
            />
            <span>{p.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .providers {
    padding: var(--ap-space-12) 0;
    border-top: none;
    border-bottom: none;
  }

  .providers-label {
    text-align: center;
    font-size: var(--ap-text-sm);
    color: var(--ap-text-tertiary);
    margin-bottom: var(--ap-space-6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .providers-track {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--ap-space-3);
  }

  .provider-chip {
    display: flex;
    align-items: center;
    gap: var(--ap-space-2);
    padding: 10px 18px;
    font-size: var(--ap-text-sm);
    font-weight: 500;
    color: var(--ap-text-secondary);
    background: var(--ap-bg-surface);
    border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius-full);
    transition:
      border-color var(--ap-ease-micro),
      color var(--ap-ease-micro),
      transform var(--ap-ease-micro);
  }

  .provider-chip:hover {
    border-color: var(--ap-border-strong);
    color: var(--ap-text-body);
    transform: translateY(-1px);
  }

  .provider-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    filter: brightness(0) invert(0.7);
    transition: filter var(--ap-ease-micro);
  }

  .provider-chip:hover .provider-icon {
    filter: brightness(0) invert(0.9);
  }

  :global([data-theme="light"]) .provider-icon {
    filter: brightness(0) invert(0.3);
  }

  :global([data-theme="light"]) .provider-chip:hover .provider-icon {
    filter: brightness(0) invert(0.1);
  }
</style>
