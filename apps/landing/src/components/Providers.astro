---
const ICON_BASE = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";

const providers = [
  { name: "Ollama", slug: "ollama" },
  { name: "Claude", slug: "claude" },
  { name: "OpenAI", slug: "openai" },
  { name: "Gemini", slug: "gemini" },
  { name: "Bedrock", slug: "bedrock" },
  { name: "Perplexity", slug: "perplexity" },
  { name: "LM Studio", slug: "lmstudio" },
  { name: "Mistral", slug: "mistral" },
  { name: "Vertex AI", slug: "vertexai" },
  { name: "Grok", slug: "grok" },
];
---

<section
  class="py-12 overflow-hidden border-b border-[var(--ap-border)]"
  aria-label="Supported AI providers"
>
  <p
    class="text-center text-sm text-[var(--ap-text-tertiary)] mb-6 uppercase tracking-widest font-medium px-4"
  >
    Works with your favorite AI providers
  </p>

  <!-- Marquee wrapper -->
  <div class="relative">
    <!-- Left fade -->
    <div
      class="pointer-events-none absolute left-0 top-0 bottom-0 w-16 z-10 bg-gradient-to-r from-[var(--ap-bg-base)] to-transparent"
    >
    </div>
    <!-- Right fade -->
    <div
      class="pointer-events-none absolute right-0 top-0 bottom-0 w-16 z-10 bg-gradient-to-l from-[var(--ap-bg-base)] to-transparent"
    >
    </div>

    <!-- Scrolling track — duplicated for seamless loop -->
    <div class="flex gap-6 provider-marquee">
      {/* First set */}
      {
        providers.map((p) => (
          <div class="flex items-center gap-2 py-2 px-1 text-sm font-medium text-[var(--ap-text-tertiary)] shrink-0 whitespace-nowrap hover:text-[var(--ap-text-primary)] transition-colors duration-200 cursor-default">
            <img
              class="w-5 h-5 shrink-0 provider-icon"
              src={`${ICON_BASE}/${p.slug}.svg`}
              alt=""
              width="20"
              height="20"
              loading="lazy"
            />
            <span>{p.name}</span>
          </div>
        ))
      }
      {/* Duplicate for seamless loop */}
      {
        providers.map((p) => (
          <div
            class="flex items-center gap-2 py-2 px-1 text-sm font-medium text-[var(--ap-text-tertiary)] shrink-0 whitespace-nowrap hover:text-[var(--ap-text-primary)] transition-colors duration-200 cursor-default"
            aria-hidden="true"
          >
            <img
              class="w-5 h-5 shrink-0 provider-icon"
              src={`${ICON_BASE}/${p.slug}.svg`}
              alt=""
              width="20"
              height="20"
              loading="lazy"
            />
            <span>{p.name}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes provider-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .provider-marquee {
    animation: provider-scroll 30s linear infinite;
    width: max-content;
  }

  .provider-icon {
    filter: brightness(0) invert(0.7);
  }
  :global([data-theme="light"]) .provider-icon {
    filter: brightness(0) invert(0.3);
  }

  @media (prefers-reduced-motion: reduce) {
    .provider-marquee {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
      gap: 0.5rem;
      padding: 0 1rem;
    }
  }
</style>
