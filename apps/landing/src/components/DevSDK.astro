---
const codeExample = `import { connect, createChat } from '@arlopass/web-sdk';

// Connect to the user's Arlopass extension
const session = await connect();

// Create a streaming chat
const chat = createChat(session);

// Send a message — user picks the model
const stream = chat.stream('Explain quantum computing simply.');

for await (const chunk of stream) {
  process.stdout.write(chunk.text);
}`;
---

<section
  id="developers"
  class="bg-[var(--ap-bg-surface)]"
  aria-labelledby="dev-heading"
>
  <div
    class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-0 items-stretch"
  >
    <div class="pl-4 md:pl-6 lg:pl-8 py-8 lg:py-24 lg:pr-12 pr-4 md:pr-6">
      <span
        class="inline-block text-sm font-pixel tracking-[0.08em] text-brand mb-4"
        >For developers</span
      >
      <h2
        id="dev-heading"
        class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight mb-6"
      >
        Add AI to your app in 10 lines.
      </h2>
      <p
        class="text-base text-[var(--ap-text-secondary)] leading-[1.7] mb-8 max-w-[520px]"
      >
        Install <code
          class="text-amber bg-[var(--ap-bg-surface)] py-0.5 px-1.5 rounded text-[0.875em]"
          >@arlopass/web-sdk</code
        >, call <code
          class="text-amber bg-[var(--ap-bg-surface)] py-0.5 px-1.5 rounded text-[0.875em]"
          >connect()</code
        >
        and <code
          class="text-amber bg-[var(--ap-bg-surface)] py-0.5 px-1.5 rounded text-[0.875em]"
          >chat.stream()</code
        >. The user's Arlopass handles provider selection, auth, and routing.
        You never see or store an API key.
      </p>

      <ul class="flex flex-col gap-3 mb-8 list-none">
        {
          [
            "Zero key management — no server proxy, no .env files",
            "TypeScript-first, Zod-validated, async iterator streaming",
            "User switches providers — your code doesn't change",
            "Free infrastructure — users bring their own AI subscriptions",
          ].map((item) => (
            <li class="flex items-start gap-2 text-sm text-[var(--ap-text-secondary)] leading-snug">
              <svg
                class="shrink-0 mt-0.5"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-success)"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>

      <a
        href="https://docs.arlopass.com/quickstart"
        class="inline-flex items-center gap-2 text-sm font-medium text-brand no-underline hover:gap-3 hover:text-amber transition-all"
      >
        Read the docs
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
    </div>

    <!-- Right side: mosaic bg + glassmorphism frame -->
    <div
      class="relative min-w-0 overflow-hidden lg:border-l border-[var(--ap-border)]"
    >
      <!-- Mosaic background (full height) -->
      <canvas
        data-mosaic-src="/img/bg6.webp"
        class="absolute inset-0 w-full h-full"></canvas>
      <div class="absolute inset-0 bg-[#FFF7ED]/40"></div>

      <div
        class="relative z-10 flex items-end pt-6 pl-6 lg:pt-16 lg:pl-16 h-full min-h-[480px]"
      >
        <!-- Glassmorphism browser frame -->
        <div class="w-full h-full">
          <div
            class="flex flex-col h-full overflow-hidden rounded-tl-2xl shadow-2xl pt-1 pl-1 bg-neutral-900/70 backdrop-blur-sm shadow-black/20 border-t border-l border-neutral-800"
          >
            <!-- Browser chrome -->
            <div
              class="hidden md:flex h-10 shrink-0 items-center gap-6 px-4 py-2"
            >
              <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-500"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
                <div class="h-3 w-3 rounded-full bg-green-500"></div>
              </div>
              <div
                class="absolute inset-y-0 inset-x-24 hidden md:flex items-center"
              >
                <div
                  class="flex flex-1 items-center justify-center gap-1.5 truncate rounded-full px-3 py-1 text-xs font-medium text-neutral-400"
                >
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="shrink-0 text-neutral-500"
                    ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                    ></rect><path d="M7 11V7a5 5 0 0110 0v4"></path></svg
                  >
                  <span class="truncate">yourapp.com/chat</span>
                </div>
              </div>
              <button
                class="ml-auto hidden md:flex items-center p-1 bg-transparent border-none text-neutral-500 cursor-pointer rounded hover:text-neutral-300 transition-colors"
                aria-label="Copy code"
                id="code-copy"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                  ></rect><path
                    d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                  ></path></svg
                >
              </button>
            </div>
            <!-- Code content -->
            <div
              class="relative h-full overflow-hidden rounded-tl-xl border-x border-t border-neutral-700/50"
            >
              <div
                class="flex items-center gap-3 py-2.5 px-4 bg-[color-mix(in_oklch,var(--ap-bg-code)_100%,#000_5%)] border-b border-white/5"
              >
                <span class="text-[11px] text-stone-500 font-mono">app.ts</span>
              </div>
              <pre
                class="p-5 h-full m-0 overflow-x-auto overflow-y-hidden scrollbar-thin font-mono lg:text-base leading-[1.7] text-stone-300 whitespace-pre break-normal max-sm:p-3 max-sm:text-[11px] bg-[var(--ap-bg-code)]"
                style="tab-size: 2"><code class="text-inherit whitespace-inherit">{codeExample}</code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById("code-copy")?.addEventListener("click", async () => {
    const code = document.querySelector("#developers pre code")?.textContent;
    if (code) await navigator.clipboard.writeText(code);
  });
</script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const codeEl = document.querySelector("#developers pre code");
    if (!codeEl) return;
    const text = codeEl.textContent || "";
    const highlighted = text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/(\/\/.*)/g, '<span style="color:#78716C">$1</span>')
      .replace(/('(?:[^'\\]|\\.)*')/g, '<span style="color:#D97706">$1</span>')
      .replace(
        /\b(import|from|const|await|for|of)\b/g,
        '<span style="color:#DB4D12">$1</span>',
      )
      .replace(
        /\b(connect|createChat|stream|write)\b(?=\()/g,
        '<span style="color:#FAFAF9">$1</span>',
      )
      .replace(/\.(stdout|text)\b/g, '.<span style="color:#D6D3D1">$1</span>');
    codeEl.innerHTML = highlighted;
  });
</script>
