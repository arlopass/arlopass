---
import type { NavItem } from "../../data/docs-nav";

interface Props {
  prev: NavItem | null;
  next: NavItem | null;
}

const { prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav
      class="border-t border-[var(--ap-border)] mt-16 pt-8 flex justify-between"
      aria-label="Page navigation"
    >
      {prev ? (
        <a
          href={`/docs/${prev.slug}`}
          class="text-sm text-[var(--ap-text-link)] hover:text-[var(--ap-text-link-hover)] transition-colors no-underline"
        >
          ← {prev.label}
        </a>
      ) : (
        <span />
      )}
      {next ? (
        <a
          href={`/docs/${next.slug}`}
          class="text-sm text-[var(--ap-text-link)] hover:text-[var(--ap-text-link-hover)] transition-colors no-underline"
        >
          {next.label} →
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
