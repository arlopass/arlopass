---
const features = [
  {
    title: "You decide who gets access",
    description:
      "When a web app wants AI, you see a clear prompt showing what it needs. Approve the connection once, pick your model, and the app is good to go.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: "Switch providers freely",
    description:
      "Use Claude for one app, GPT for another, Ollama for everything sensitive. Switch with a click — no code changes, no reconfiguration.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>`,
  },
  {
    title: "Local model support",
    description:
      "Connect Ollama or LM Studio for fully local, zero-cloud AI. Your prompts never leave your machine. Everything stays on your hardware.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  },
  {
    title: "Enterprise governance",
    description:
      "Signed policy bundles enforce approved providers, model restrictions, and data-handling rules. Ed25519-signed, JSONL audit trails, OTLP export.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>`,
  },
  {
    title: "Works everywhere",
    description:
      "Any web app can integrate Arlopass. Install the extension once, use it across every Arlopass-enabled site. One pass, every app.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  },
  {
    title: "Open source, MIT licensed",
    description:
      "The protocol, SDK, extension, and every adapter — all MIT licensed. Use it, fork it, extend it. AI access on the web should be a standard, not a moat.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  },
];
---

<section class="py-24" id="features" aria-labelledby="features-heading">
  <div class="px-4 md:px-6 lg:px-8">
    <div class="text-center max-w-[600px] mx-auto mb-16">
      <span
        class="inline-block text-xs font-medium uppercase tracking-[0.08em] text-brand mb-4"
        >What you get</span
      >
      <h2
        id="features-heading"
        class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight"
      >
        Built around what matters to you
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6">
      {
        features.map((f) => (
          <div class="flex gap-4 p-6 rounded-lg hover:bg-[var(--ap-bg-surface)] transition-colors">
            <div
              class="flex items-center justify-center shrink-0 w-10 h-10 rounded-lg bg-brand-subtle-dark text-brand"
              set:html={f.icon}
            />
            <div>
              <h3 class="text-base font-semibold mb-1">{f.title}</h3>
              <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
                {f.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
