---
const features = [
  {
    label: "Access control",
    title: "You decide who gets access",
    description:
      "When a web app wants AI, you see a clear prompt showing what it needs. Approve the connection once, pick your model, and the app is good to go.",
  },
  {
    label: "Multi-provider",
    title: "Switch providers freely",
    description:
      "Use Claude for one app, GPT for another, Ollama for everything sensitive. Switch with a click — no code changes, no reconfiguration.",
  },
  {
    label: "Local-first",
    title: "Local model support",
    description:
      "Connect Ollama or LM Studio for fully local, zero-cloud AI. Your prompts never leave your machine. Everything stays on your hardware.",
  },
  {
    label: "Governance",
    title: "Enterprise governance",
    description:
      "Signed policy bundles enforce approved providers, model restrictions, and data-handling rules. Ed25519-signed, JSONL audit trails, OTLP export.",
  },
  {
    label: "Universal",
    title: "Works everywhere",
    description:
      "Any web app can integrate Arlopass. Install the extension once, use it across every Arlopass-enabled site. One pass, every app.",
  },
  {
    label: "Open source",
    title: "Open source, MIT licensed",
    description:
      "The protocol, SDK, extension, and every adapter — all MIT licensed. Use it, fork it, extend it. AI access on the web should be a standard, not a moat.",
  },
];
---

<section
  class="bg-[var(--ap-bg-surface)]"
  id="features"
  aria-labelledby="features-heading"
>
  <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
    <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
      >What you get</span
    >
    <h2
      id="features-heading"
      class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
    >
      Built around what matters to you
    </h2>
    <p
      class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
    >
      Privacy, choice, and developer experience — without compromise.
    </p>
  </div>

  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border border-[var(--ap-border)] [&>*]:border-b [&>*]:border-[var(--ap-border)] [&>*:nth-child(odd)]:sm:border-r [&>*]:lg:border-r [&>*:nth-child(3n)]:lg:border-r-0 [&>*:nth-last-child(-n+3)]:lg:border-b-0 [&>*:nth-last-child(-n+2)]:sm:border-b-0 [&>*:nth-last-child(-n+2)]:lg:border-b [&>*:nth-last-child(-n+3)]:lg:border-b-0 [&>*:last-child]:border-b-0"
  >
    {
      features.map((f) => (
        <div class="bg-[var(--ap-bg-surface)] hover:bg-[var(--ap-bg-base)] transition-colors ease-in-out duration-300 p-8 sm:p-10">
          <span class="text-sm font-pixel tracking-[0.08em] text-brand">
            {f.label}
          </span>
          <h3 class="mt-2 text-lg font-semibold tracking-tight text-[var(--ap-text-primary)] mb-2">
            {f.title}
          </h3>
          <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
            {f.description}
          </p>
        </div>
      ))
    }
  </div>
</section>
