---

---

<nav
  class="sticky top-0 z-50 bg-[var(--ap-bg-base)] border-b border-[var(--ap-border)]"
  aria-label="Main navigation"
>
  <div class="px-4 md:px-6 lg:px-8 flex items-center h-[60px] gap-8">
    <a
      href="/"
      class="flex items-center shrink-0 no-underline"
      aria-label="Arlopass home"
    >
      <img
        src="/ArlopassLogo-Light.svg"
        alt="Arlopass"
        class="h-5 w-auto"
        id="logo-light"
      />
      <img
        src="/ArlopassLogo-Dark.svg"
        alt="Arlopass"
        class="h-5 w-auto hidden"
        id="logo-dark"
      />
    </a>

    <div class="hidden md:flex items-center gap-6 ml-4" id="nav-links">
      <a
        href="/docs"
        class="text-sm font-[450] text-[var(--ap-text-secondary)] no-underline hover:text-[var(--ap-text-primary)] transition-colors"
        >Docs</a
      >
    </div>

    <div class="flex items-center gap-3 ml-auto">
      <a
        href="https://github.com/arlopass"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center text-[var(--ap-text-tertiary)] hover:text-[var(--ap-text-primary)] transition-colors"
        aria-label="GitHub"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path></svg
        >
      </a>
      <button
        id="theme-toggle"
        class="flex items-center justify-center w-8 h-8 rounded-md bg-transparent border border-[var(--ap-border)] text-[var(--ap-text-tertiary)] hover:text-[var(--ap-text-primary)] hover:border-[var(--ap-border-strong)] transition-all cursor-pointer"
        aria-label="Toggle theme"
      >
        <svg
          class="theme-icon-sun"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg
        >
        <svg
          class="theme-icon-moon hidden"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path></svg
        >
      </button>
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex text-sm font-medium text-[var(--ap-text-primary)] bg-transparent py-[7px] px-4 border border-[var(--ap-border-strong)] rounded-lg no-underline whitespace-nowrap hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] hover:text-[var(--ap-text-primary)] transition-all"
      >
        Install extension
      </a>
      <button
        class="md:hidden flex items-center justify-center w-10 h-10 p-0 bg-transparent border-none text-[var(--ap-text-secondary)] cursor-pointer hover:text-[var(--ap-text-primary)]"
        id="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <svg
          class="nav-toggle-open"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="3" y1="6" x2="21" y2="6"></line><line
            x1="3"
            y1="12"
            x2="21"
            y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
        <svg
          class="nav-toggle-close hidden"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="18" y1="6" x2="6" y2="18"></line><line
            x1="6"
            y1="6"
            x2="18"
            y2="18"></line></svg
        >
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    class="hidden md:hidden flex-col items-stretch px-4 py-3 pb-5 bg-[var(--ap-bg-base)] border-b border-[var(--ap-border)]"
    id="nav-mobile"
  >
    <a
      href="/docs"
      class="py-2.5 px-3 rounded text-base text-[var(--ap-text-secondary)] no-underline hover:bg-[var(--ap-bg-surface)] hover:text-[var(--ap-text-primary)]"
      >Docs</a
    >
    <a
      href="/install"
      class="py-2.5 px-3 rounded text-base text-[var(--ap-text-secondary)] no-underline hover:bg-[var(--ap-bg-surface)] hover:text-[var(--ap-text-primary)]"
      >Install</a
    >
  </div>
</nav>

<script>
  // Theme toggle
  const themeBtn = document.getElementById("theme-toggle");
  const logoLight = document.getElementById("logo-light");
  const logoDark = document.getElementById("logo-dark");

  function updateThemeUI() {
    const isDark =
      document.documentElement.getAttribute("data-theme") === "dark";
    themeBtn
      ?.querySelector(".theme-icon-sun")
      ?.classList.toggle("hidden", !isDark);
    themeBtn
      ?.querySelector(".theme-icon-moon")
      ?.classList.toggle("hidden", isDark);
    logoLight?.classList.toggle("hidden", isDark);
    logoDark?.classList.toggle("hidden", !isDark);
  }

  // Restore saved theme
  const saved = localStorage.getItem("arlopass-theme");
  if (saved) {
    document.documentElement.setAttribute("data-theme", saved);
  }
  updateThemeUI();

  if (themeBtn) {
    themeBtn.addEventListener("click", () => {
      const html = document.documentElement;
      const current = html.getAttribute("data-theme");
      const next = current === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      localStorage.setItem("arlopass-theme", next);
      updateThemeUI();
    });
  }

  // Mobile nav toggle
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");
  if (toggle && mobile) {
    toggle.addEventListener("click", () => {
      const open = mobile.classList.toggle("!flex");
      mobile.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle
        .querySelector(".nav-toggle-open")
        ?.classList.toggle("hidden", open);
      toggle
        .querySelector(".nav-toggle-close")
        ?.classList.toggle("hidden", !open);
    });
    mobile.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        mobile.classList.add("hidden");
        mobile.classList.remove("!flex");
        toggle.setAttribute("aria-expanded", "false");
        toggle.querySelector(".nav-toggle-open")?.classList.remove("hidden");
        toggle.querySelector(".nav-toggle-close")?.classList.add("hidden");
      });
    });
  }
</script>
