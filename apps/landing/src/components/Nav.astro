---

---

<nav class="nav" aria-label="Main navigation">
  <div class="nav-inner container">
    <a href="/" class="logo" aria-label="Arlopass home">
      <img
        src="/ArlopassLogo-Dark.svg"
        alt="Arlopass"
        class="logo-img logo-dark"
        width="130"
        height="22"
      />
      <img
        src="/ArlopassLogo-Light.svg"
        alt="Arlopass"
        class="logo-img logo-light"
        width="130"
        height="22"
      />
    </a>

    <div class="nav-links">
      <a href="#how-it-works">How It Works</a>
      <a href="#developers">Developers</a>
      <a href="#privacy">Privacy</a>
      <a href="#faq">FAQ</a>
      <a
        href="https://github.com/arlopass"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-github"
        aria-label="GitHub"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
    </div>

    <a
      href="https://chrome.google.com/webstore"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-cta"
    >
      Install Extension
    </a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: color-mix(in oklch, var(--ap-bg-base) 80%, transparent);
    border-bottom: 1px solid var(--ap-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: var(--ap-space-6);
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 22px;
    width: auto;
  }

  .logo-light {
    display: none;
  }

  [data-theme="light"] .logo-dark {
    display: none;
  }
  [data-theme="light"] .logo-light {
    display: block;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: var(--ap-space-8);
  }

  .nav-links a {
    font-size: var(--ap-text-sm);
    color: var(--ap-text-secondary);
    font-weight: 500;
    transition: color var(--ap-ease-micro);
  }
  .nav-links a:hover {
    color: var(--ap-text-primary);
  }

  .nav-github {
    display: flex;
    align-items: center;
    color: var(--ap-text-secondary);
  }
  .nav-github:hover {
    color: var(--ap-text-primary);
  }

  .nav-cta {
    font-size: var(--ap-text-sm);
    font-weight: 500;
    color: #fafaf9;
    background: var(--ap-brand);
    padding: 8px 16px;
    border-radius: var(--ap-radius-sm);
    text-decoration: none;
    transition: background var(--ap-ease-micro);
    white-space: nowrap;
  }
  .nav-cta:hover {
    background: var(--ap-brand-hover);
    color: #fafaf9;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }
</style>
