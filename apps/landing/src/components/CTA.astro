---

---

<section
  class="relative py-24 text-center overflow-hidden"
  aria-labelledby="cta-heading"
>
  <div
    class="absolute -top-[200px] left-1/2 -translate-x-1/2 w-[700px] h-[500px] bg-[radial-gradient(ellipse,color-mix(in_oklch,var(--color-brand)_12%,transparent),transparent_70%)] pointer-events-none"
  >
  </div>
  <div class="relative z-10 px-4 md:px-6 lg:px-8">
    <h2
      id="cta-heading"
      class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight mb-4"
    >
      Ready to take control?
    </h2>
    <p
      class="text-lg text-[var(--ap-text-secondary)] max-w-[520px] mx-auto mb-10 leading-relaxed"
    >
      Install Arlopass, connect your AI providers, and start using AI on your
      terms. Free, open source, and ready right now.
    </p>
    <div
      class="flex flex-wrap justify-center gap-3 max-[480px]:flex-col max-[480px]:items-stretch max-[480px]:px-4"
    >
      <a
        href="https://chrome.google.com/webstore"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 text-sm font-medium text-stone-50 bg-[var(--ap-text-primary)] py-3.5 px-7 rounded-lg no-underline hover:opacity-85 hover:text-stone-50 transition-opacity"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path><polyline
            points="7 10 12 15 17 10"></polyline><line
            x1="12"
            y1="15"
            x2="12"
            y2="3"></line></svg
        >
        Install for Chrome
      </a>
      <a
        href="https://docs.arlopass.com/quickstart"
        class="inline-flex items-center justify-center gap-2 text-sm font-medium text-[var(--ap-text-primary)] bg-transparent border border-[var(--ap-border-strong)] py-3.5 px-7 rounded-lg no-underline hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] hover:text-[var(--ap-text-primary)] transition-all"
      >
        Read the quickstart
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
    </div>
  </div>
</section>
