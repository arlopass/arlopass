---
const rows = [
  {
    cap: "User chooses the model",
    ap: true,
    paste: "Depends",
    gw: false,
    sdk: false,
  },
  {
    cap: "Keys never leave user's device",
    ap: true,
    paste: false,
    gw: false,
    sdk: false,
  },
  {
    cap: "Works with local models",
    ap: true,
    paste: "Rarely",
    gw: "Sometimes",
    sdk: false,
  },
  {
    cap: "Zero server infrastructure",
    ap: true,
    paste: false,
    gw: false,
    sdk: false,
  },
  {
    cap: "Integration effort",
    ap: "~10 lines",
    paste: "~40+ lines",
    gw: "~30 lines",
    sdk: "~15 lines",
  },
  {
    cap: "Provider switching",
    ap: "0 code changes",
    paste: "Full rewrite",
    gw: "Config change",
    sdk: "Moderate",
  },
  {
    cap: "Enterprise policy & audit",
    ap: true,
    paste: false,
    gw: true,
    sdk: false,
  },
  {
    cap: "User approves app connection",
    ap: true,
    paste: false,
    gw: false,
    sdk: false,
  },
  { cap: "Open source", ap: true, paste: "Varies", gw: "Some", sdk: "Some" },
];

const check =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
const dash =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>';

function cell(v: boolean | string) {
  if (v === true) return { h: check, c: "text-success font-semibold" };
  if (v === false) return { h: dash, c: "text-[var(--ap-text-tertiary)]" };
  return {
    h: String(v),
    c: "text-[var(--ap-text-secondary)] font-mono text-xs",
  };
}
---

<section class="bg-[var(--ap-bg-surface)]" aria-labelledby="comparison-heading">
  <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
    <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
      >Why Arlopass</span
    >
    <h2
      id="comparison-heading"
      class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
    >
      Other tools ask you to trust them with your keys. Arlopass lets you keep
      them.
    </h2>
  </div>

  <div class="overflow-x-auto -webkit-overflow-scrolling-touch">
    <table
      class="w-full min-w-[600px] border-collapse text-sm max-sm:text-xs border border-[var(--ap-border)]"
      role="table"
    >
      <thead>
        <tr>
          <th
            class="py-3.5 px-5 text-left text-xs font-medium text-[var(--ap-text-tertiary)] font-pixel tracking-wider border-b border-r border-[var(--ap-border)] bg-[var(--ap-bg-surface)] whitespace-nowrap max-sm:py-2.5 max-sm:px-3"
            >Capability</th
          >
          <th
            class="py-3.5 px-5 text-left text-xs font-semibold text-brand font-pixel tracking-wider border-b border-r border-[var(--ap-border)] bg-brand-subtle whitespace-nowrap max-sm:py-2.5 max-sm:px-3"
            >Arlopass</th
          >
          <th
            class="py-3.5 px-5 text-left text-xs font-medium text-[var(--ap-text-tertiary)] font-pixel tracking-wider border-b border-r border-[var(--ap-border)] bg-[var(--ap-bg-surface)] whitespace-nowrap max-sm:py-2.5 max-sm:px-3"
            >Paste API Key</th
          >
          <th
            class="py-3.5 px-5 text-left text-xs font-medium text-[var(--ap-text-tertiary)] font-pixel tracking-wider border-b border-r border-[var(--ap-border)] bg-[var(--ap-bg-surface)] whitespace-nowrap max-sm:py-2.5 max-sm:px-3"
            >AI Gateways</th
          >
          <th
            class="py-3.5 px-5 text-left text-xs font-medium text-[var(--ap-text-tertiary)] font-pixel tracking-wider border-b border-[var(--ap-border)] bg-[var(--ap-bg-surface)] whitespace-nowrap max-sm:py-2.5 max-sm:px-3"
            >Vendor SDKs</th
          >
        </tr>
      </thead>
      <tbody>
        {
          rows.map((r) => (
            <tr class="hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 last:*:border-b-0">
              <td class="py-3.5 px-5 border-b border-r border-[var(--ap-border)] text-[var(--ap-text-primary)] font-medium bg-white max-sm:py-2.5 max-sm:px-3">
                {r.cap}
              </td>
              <td
                class={`py-3.5 px-5 border-b border-r border-[var(--ap-border)] bg-brand-subtle/30 ${cell(r.ap).c} max-sm:py-2.5 max-sm:px-3`}
                set:html={cell(r.ap).h}
              />
              <td
                class={`py-3.5 px-5 border-b border-r border-[var(--ap-border)] bg-white ${cell(r.paste).c} max-sm:py-2.5 max-sm:px-3`}
                set:html={cell(r.paste).h}
              />
              <td
                class={`py-3.5 px-5 border-b border-r border-[var(--ap-border)] bg-white ${cell(r.gw).c} max-sm:py-2.5 max-sm:px-3`}
                set:html={cell(r.gw).h}
              />
              <td
                class={`py-3.5 px-5 border-b border-[var(--ap-border)] bg-white ${cell(r.sdk).c} max-sm:py-2.5 max-sm:px-3`}
                set:html={cell(r.sdk).h}
              />
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
