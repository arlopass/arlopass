---
/**
 * Preview: Secure Vault — credential storage in OS keychain
 * Uses data-step stagger for reveal. No custom script needed.
 */
const IC = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";
---

<div data-preview class="w-full h-full">
  <div class="flex flex-col h-full w-full gap-2">
    <!-- Header -->
    <div
      data-step="0"
      class="flex items-center gap-2 pb-2 border-b border-[var(--ap-border)] shrink-0"
    >
      <img
        src="/ArlopassIcon.svg"
        alt=""
        width="14"
        height="14"
        aria-hidden="true"
      />
      <span
        class="text-[10px] font-semibold text-[var(--ap-text-primary)] flex-1"
        >Credential Vault</span
      >
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-success)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path
          d="M7 11V7a5 5 0 0110 0v4"></path></svg
      >
    </div>

    <!-- Credential rows -->
    <div
      data-step="1"
      class="flex items-center gap-2 py-1.5 px-2.5 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg"
    >
      <img
        src={`${IC}/claude-color.svg`}
        alt=""
        width="16"
        height="16"
        class="shrink-0"
      />
      <div class="flex-1 min-w-0">
        <p class="text-[9px] font-medium text-[var(--ap-text-primary)]">
          Claude API Key
        </p>
        <p class="text-[7px] font-mono text-[var(--ap-text-tertiary)]">
          sk-ant-•••••k3m
        </p>
      </div>
      <svg
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-success)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="20 6 9 17 4 12"></polyline></svg
      >
    </div>

    <div
      data-step="2"
      class="flex items-center gap-2 py-1.5 px-2.5 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg"
    >
      <img
        src={`${IC}/openai.svg`}
        alt=""
        width="16"
        height="16"
        class="shrink-0"
      />
      <div class="flex-1 min-w-0">
        <p class="text-[9px] font-medium text-[var(--ap-text-primary)]">
          OpenAI API Key
        </p>
        <p class="text-[7px] font-mono text-[var(--ap-text-tertiary)]">
          sk-proj-•••••x9f
        </p>
      </div>
      <svg
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-success)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="20 6 9 17 4 12"></polyline></svg
      >
    </div>

    <div
      data-step="3"
      class="flex items-center gap-2 py-1.5 px-2.5 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg"
    >
      <img
        src={`${IC}/bedrock-color.svg`}
        alt=""
        width="16"
        height="16"
        class="shrink-0"
      />
      <div class="flex-1 min-w-0">
        <p class="text-[9px] font-medium text-[var(--ap-text-primary)]">
          AWS Bedrock
        </p>
        <p class="text-[7px] font-mono text-[var(--ap-text-tertiary)]">
          AKIA•••••••VN2
        </p>
      </div>
      <svg
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-success)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="20 6 9 17 4 12"></polyline></svg
      >
    </div>

    <!-- Security footer -->
    <div
      data-step="4"
      class="flex items-center gap-1.5 pt-2 border-t border-[var(--ap-border)] mt-auto shrink-0"
    >
      <svg
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-brand)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
      >
      <span class="text-[8px] text-[var(--ap-text-tertiary)]"
        >AES-256-GCM · OS Keychain · Zero-server</span
      >
    </div>
  </div>
</div>
