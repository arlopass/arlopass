---
/**
 * Preview: Install Extension — Chrome Web Store install flow
 * Shows the extension being installed in 3 stages:
 * 1. Chrome Web Store listing appears
 * 2. "Add to Chrome" clicked → installing spinner
 * 3. Extension installed success with icon in toolbar
 */
---

<div data-preview data-loop="9000" class="w-full h-full">
  <div class="flex flex-col h-full w-full gap-2.5">
    <!-- Chrome Web Store header -->
    <div
      id="inst-header"
      class="flex items-center gap-2 pb-2 border-b border-[var(--ap-border)] shrink-0 opacity-0 transition-all duration-400"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--ap-text-tertiary)"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="4"
        ></circle><line x1="21.17" y1="8" x2="12" y2="8"></line><line
          x1="3.95"
          y1="6.06"
          x2="8.54"
          y2="14"></line><line x1="10.88" y1="21.94" x2="15.46" y2="14"
        ></line></svg
      >
      <span
        class="text-[10px] font-semibold text-[var(--ap-text-primary)] flex-1"
        >Chrome Web Store</span
      >
    </div>

    <!-- Extension listing -->
    <div
      id="inst-listing"
      class="flex items-center gap-2.5 py-2 px-2.5 border border-[var(--ap-border)] rounded-lg opacity-0 transition-all duration-400"
    >
      <div
        class="w-9 h-9 rounded-lg bg-white border border-[var(--ap-border)] flex items-center justify-center shrink-0 overflow-hidden"
      >
        <img
          src="/ArlopassIcon.svg"
          alt=""
          width="22"
          height="22"
          class="w-5.5 h-5.5"
        />
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-[10px] font-semibold text-[var(--ap-text-primary)]">
          Arlopass
        </p>
        <p class="text-[7px] text-[var(--ap-text-tertiary)] mt-0.5">
          Your AI, your models, your rules.
        </p>
        <div class="flex items-center gap-1 mt-1">
          <div class="flex gap-px">
            {
              [1, 2, 3, 4, 5].map(() => (
                <svg
                  width="8"
                  height="8"
                  viewBox="0 0 24 24"
                  fill="var(--color-amber)"
                  stroke="none"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              ))
            }
          </div>
          <span class="text-[7px] text-[var(--ap-text-tertiary)]">5.0</span>
        </div>
      </div>
    </div>

    <!-- Add to Chrome button -->
    <div id="inst-btn" class="opacity-0 transition-all duration-400">
      <button
        id="inst-add-btn"
        class="w-full py-2.5 px-3 rounded-lg text-[10px] font-semibold text-white bg-[#1a73e8] transition-all duration-300 flex items-center justify-center gap-1.5"
        type="button"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="12" y1="5" x2="12" y2="19"></line><line
            x1="5"
            y1="12"
            x2="19"
            y2="12"></line></svg
        >
        Add to Chrome
      </button>
    </div>

    <!-- Installing state -->
    <div
      id="inst-installing"
      class="flex items-center gap-2.5 py-2 px-3 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg hidden"
    >
      <div
        class="w-4 h-4 border-2 border-brand/30 border-t-brand rounded-full animate-spin shrink-0"
      >
      </div>
      <span class="text-[10px] text-[var(--ap-text-secondary)]"
        >Installing Arlopass…</span
      >
    </div>

    <!-- Success state -->
    <div
      id="inst-success"
      class="flex-col gap-2 hidden"
    >
      <div
        class="flex items-center gap-2 py-2.5 px-3 bg-[var(--ap-success-subtle)] border border-success/20 rounded-lg"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--color-success)"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="20 6 9 17 4 12"></polyline></svg
        >
        <span class="text-[10px] font-medium text-success"
          >Arlopass added to Chrome</span
        >
      </div>
      <!-- Toolbar mockup -->
      <div
        class="flex items-center justify-end gap-1 py-2 px-2.5 border border-[var(--ap-border)] rounded-lg"
      >
        <span class="text-[8px] text-[var(--ap-text-tertiary)] mr-auto"
          >Extensions</span
        >
        <div
          class="w-5 h-5 rounded bg-[var(--ap-brand-subtle)] border border-brand/20 flex items-center justify-center"
        >
          <img
            src="/ArlopassIcon.svg"
            alt=""
            width="12"
            height="12"
            class="w-3 h-3"
          />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function instRun(p: HTMLElement) {
    const q = (s: string) => p.querySelector(s) as HTMLElement | null;
    const tt: number[] = [];
    const t = (fn: () => void, ms: number) =>
      tt.push(window.setTimeout(fn, ms));
    const show = (el: HTMLElement | null) => {
      if (el) el.style.opacity = "1";
    };
    const hide = (el: HTMLElement | null) => {
      if (el) el.style.opacity = "0";
    };
    const reveal = (el: HTMLElement | null) => {
      if (el) {
        el.classList.remove("hidden");
        el.style.display = "flex";
      }
    };
    const collapse = (el: HTMLElement | null) => {
      if (el) {
        el.style.display = "none";
        el.classList.add("hidden");
      }
    };

    // Stagger reveal
    t(() => show(q("#inst-header")), 300);
    t(() => show(q("#inst-listing")), 700);
    t(() => show(q("#inst-btn")), 1100);

    // Click "Add to Chrome"
    t(() => {
      const btn = q("#inst-add-btn");
      if (btn) {
        btn.style.opacity = "0.7";
        btn.style.transform = "scale(0.97)";
      }
    }, 2500);
    t(() => {
      const btn = q("#inst-add-btn");
      if (btn) {
        btn.style.opacity = "1";
        btn.style.transform = "";
      }
    }, 2700);

    // Hide button, show installing
    t(() => {
      collapse(q("#inst-btn"));
      reveal(q("#inst-installing"));
    }, 3000);

    // Hide installing, show success
    t(() => {
      collapse(q("#inst-installing"));
      reveal(q("#inst-success"));
    }, 5000);

    // Reset
    t(() => {
      ["#inst-header", "#inst-listing"].forEach((id) => hide(q(id)));
      const btn = q("#inst-btn");
      if (btn) {
        btn.style.display = "";
        btn.style.opacity = "0";
      }
      const addBtn = q("#inst-add-btn");
      if (addBtn) {
        addBtn.style.opacity = "";
        addBtn.style.transform = "";
      }
      collapse(q("#inst-installing"));
      collapse(q("#inst-success"));
      p.dispatchEvent(new CustomEvent("preview:done", { bubbles: false }));
    }, 8000);

    return tt;
  }

  const instP = document.querySelector(
    "[data-preview]:has(#inst-header)",
  ) as HTMLElement;
  if (instP) {
    let at: number[] = [];
    const reset = () => {
      at.forEach(clearTimeout);
      at = [];
      const q = (s: string) => instP.querySelector(s) as HTMLElement | null;
      ["#inst-header", "#inst-listing"].forEach((id) => {
        const el = q(id);
        if (el) el.style.opacity = "0";
      });
      const btn = q("#inst-btn");
      if (btn) {
        btn.style.display = "";
        btn.style.opacity = "0";
      }
      const addBtn = q("#inst-add-btn");
      if (addBtn) {
        addBtn.style.opacity = "";
        addBtn.style.transform = "";
      }
      const installing = q("#inst-installing");
      if (installing) {
        installing.style.display = "none";
        installing.classList.add("hidden");
      }
      const success = q("#inst-success");
      if (success) {
        success.style.display = "none";
        success.classList.add("hidden");
      }
    };
    const obs = new MutationObserver(() => {
      if (instP.classList.contains("preview-active")) {
        reset();
        at = instRun(instP) || [];
      } else {
        reset();
      }
    });
    obs.observe(instP, { attributes: true, attributeFilter: ["class"] });
    instP.addEventListener("preview:loop", () => {
      reset();
      at = instRun(instP) || [];
    });
    if (instP.classList.contains("preview-active")) {
      at = instRun(instP) || [];
    }
  }
</script>
