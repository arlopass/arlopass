---
/**
 * Preview: Model switching flow
 * Shows a user switching between AI providers mid-session
 */
import PreviewPanel from "../ui/PreviewPanel.astro";

const ICON_BASE = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";
---

<PreviewPanel>
  <div data-step="0" class="flex items-center gap-2">
    <img
      src="/ArlopassIcon.svg"
      alt=""
      width="18"
      height="18"
      aria-hidden="true"
    />
    <span class="text-sm font-semibold text-[var(--ap-text-primary)] flex-1"
      >Arlopass</span
    >
    <span
      class="text-[10px] font-medium text-[var(--ap-text-tertiary)] py-0.5 px-2 border border-[var(--ap-border)] rounded-full uppercase tracking-wide"
      >Switch model</span
    >
  </div>

  <p data-step="1" class="text-sm text-[var(--ap-text-secondary)] leading-snug">
    Choose a different provider for notes-app.io
  </p>

  <div data-step="2" class="flex flex-col gap-1.5">
    <div
      class="flex items-center gap-2 py-2 px-2.5 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded text-xs font-medium text-[var(--ap-text-secondary)]"
    >
      <img
        src={`${ICON_BASE}/ollama.svg`}
        alt=""
        width="16"
        height="16"
        class="w-4 h-4 provider-icon"
      />
      <span>Ollama · Llama 3</span>
    </div>
    <div
      class="flex items-center gap-2 py-2 px-2.5 border border-brand rounded text-xs font-medium text-brand bg-brand-subtle"
    >
      <img
        src={`${ICON_BASE}/openai.svg`}
        alt=""
        width="16"
        height="16"
        class="w-4 h-4 provider-icon"
      />
      <span>GPT-4o</span>
      <svg
        class="ml-auto"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
      >
    </div>
    <div
      class="flex items-center gap-2 py-2 px-2.5 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded text-xs font-medium text-[var(--ap-text-secondary)]"
    >
      <img
        src={`${ICON_BASE}/gemini.svg`}
        alt=""
        width="16"
        height="16"
        class="w-4 h-4 provider-icon"
      />
      <span>Gemini 2.0 Flash</span>
    </div>
  </div>

  <div data-step="3" class="flex gap-2 mt-1">
    <button
      class="flex-1 py-2 px-3 text-xs font-medium text-stone-50 bg-brand border-none rounded cursor-default font-sans"
      >Confirm switch</button
    >
  </div>
</PreviewPanel>

<style>
  .provider-icon {
    filter: brightness(0) invert(0.3);
  }
</style>
