---
/**
 * Preview: App Connection Approval — multi-screen wizard flow
 *
 * Screens:
 * 1. App info + connection request
 * 2. Select providers to grant access
 * 3. Select models to allow
 * 4. Confirm connection summary
 * 5. Connecting spinner
 * 6. Success with summary
 */
import PreviewPanel from "../ui/PreviewPanel.astro";
import ClickPing from "../ui/ClickPing.astro";
const IC = "https://unpkg.com/@lobehub/icons-static-svg@latest/icons";
---

<PreviewPanel loop={16000}>
  <!-- Screen 1: App connection request -->
  <div id="aca-s1" class="flex flex-col gap-3 transition-opacity duration-350">
    <div
      data-step="0"
      class="flex items-center gap-2 pb-2.5 border-b border-[var(--ap-border)]"
    >
      <img
        src="/ArlopassIcon.svg"
        alt=""
        width="16"
        height="16"
        aria-hidden="true"
      />
      <span class="text-xs font-semibold text-[var(--ap-text-primary)] flex-1"
        >Arlopass</span
      >
      <span
        id="aca-badge"
        class="aca-badge-pending text-[9px] font-semibold py-0.5 px-2 rounded-full uppercase tracking-wide transition-all duration-300"
        >New request</span
      >
    </div>

    <div
      data-step="1"
      class="flex items-center gap-3 py-2 px-3 bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg"
    >
      <div
        class="w-8 h-8 rounded-md bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] flex items-center justify-center shrink-0 overflow-hidden"
      >
        <img
          src="https://excalimate.com/favicon.svg"
          alt=""
          width="20"
          height="20"
          class="w-5 h-5"
        />
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs font-semibold text-[var(--ap-text-primary)] truncate">
          excalimate.com
        </p>
        <p class="text-[10px] text-[var(--ap-text-tertiary)] truncate">
          Animated whiteboard presentations
        </p>
      </div>
    </div>

    <p
      data-step="2"
      class="text-xs text-[var(--ap-text-secondary)] leading-relaxed"
    >
      This app wants to connect to your AI providers through Arlopass.
    </p>

    <div data-step="3" class="flex gap-2 mt-1">
      <button
        class="flex-1 py-2 px-3 text-xs font-medium text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-md cursor-default font-sans"
        >Deny</button
      >
      <button
        id="aca-next1"
        class="flex-1 py-2 px-3 text-xs font-medium text-stone-50 bg-brand border-none rounded-md cursor-default font-sans transition-all duration-200"
        >Continue</button
      >
    </div>
  </div>

  <!-- Screen 2: Select providers -->
  <div id="aca-s2" class="hidden flex-col gap-3" data-aca-screen>
    <div
      class="flex items-center gap-2 pb-2.5 border-b border-[var(--ap-border)]"
    >
      <svg
        class="text-[var(--ap-text-tertiary)]"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="15 18 9 12 15 6"></polyline></svg
      >
      <span class="text-xs font-semibold text-[var(--ap-text-primary)] flex-1"
        >Select providers</span
      >
      <span class="text-[9px] text-[var(--ap-text-tertiary)]">Step 1 of 2</span>
    </div>
    <p class="text-[10px] text-[var(--ap-text-tertiary)] leading-relaxed">
      Choose which providers excalimate.com can use:
    </p>
    <div class="flex flex-col gap-1.5">
      <label
        id="aca-p0"
        class="flex items-center gap-2 py-1.5 px-2.5 rounded-md text-xs text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] cursor-default transition-all duration-200"
      >
        <div
          class="w-4 h-4 rounded border border-[var(--ap-border)] bg-[var(--ap-bg-base)] flex items-center justify-center transition-all duration-200 aca-check shrink-0"
        >
        </div>
        <img
          src={`${IC}/ollama.svg`}
          alt=""
          width="14"
          height="14"
          class="w-3.5 h-3.5 picon"
        />
        <span class="flex-1">Ollama</span>
      </label>
      <label
        id="aca-p1"
        class="flex items-center gap-2 py-1.5 px-2.5 rounded-md text-xs text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] cursor-default transition-all duration-200"
      >
        <div
          class="w-4 h-4 rounded border border-[var(--ap-border)] bg-[var(--ap-bg-base)] flex items-center justify-center transition-all duration-200 aca-check shrink-0"
        >
        </div>
        <img
          src={`${IC}/claude.svg`}
          alt=""
          width="14"
          height="14"
          class="w-3.5 h-3.5 picon"
        />
        <span class="flex-1">Claude</span>
      </label>
      <label
        id="aca-p2"
        class="flex items-center gap-2 py-1.5 px-2.5 rounded-md text-xs text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] cursor-default transition-all duration-200"
      >
        <div
          class="w-4 h-4 rounded border border-[var(--ap-border)] bg-[var(--ap-bg-base)] flex items-center justify-center transition-all duration-200 aca-check shrink-0"
        >
        </div>
        <img
          src={`${IC}/openai.svg`}
          alt=""
          width="14"
          height="14"
          class="w-3.5 h-3.5 picon"
        />
        <span class="flex-1">OpenAI</span>
      </label>
    </div>
    <button
      id="aca-next2"
      class="w-full py-2 px-3 text-xs font-medium text-stone-50 bg-brand border-none rounded-md cursor-default font-sans transition-all duration-200 mt-1 opacity-50"
      >Next</button
    >
  </div>

  <!-- Screen 3: Select models -->
  <div id="aca-s3" class="hidden flex-col gap-3" data-aca-screen>
    <div
      class="flex items-center gap-2 pb-2.5 border-b border-[var(--ap-border)]"
    >
      <svg
        class="text-[var(--ap-text-tertiary)]"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="15 18 9 12 15 6"></polyline></svg
      >
      <span class="text-xs font-semibold text-[var(--ap-text-primary)] flex-1"
        >Select models</span
      >
      <span class="text-[9px] text-[var(--ap-text-tertiary)]">Step 2 of 2</span>
    </div>
    <p class="text-[10px] text-[var(--ap-text-tertiary)] leading-relaxed">
      Choose which models to allow:
    </p>
    <div class="flex flex-col gap-1.5">
      <label
        id="aca-m0"
        class="flex items-center gap-2 py-1.5 px-2.5 rounded-md text-xs text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] cursor-default transition-all duration-200"
      >
        <div
          class="w-4 h-4 rounded border border-[var(--ap-border)] bg-[var(--ap-bg-base)] flex items-center justify-center transition-all duration-200 aca-check shrink-0"
        >
        </div>
        <span class="flex-1">Claude 3.5 Sonnet</span>
      </label>
      <label
        id="aca-m1"
        class="flex items-center gap-2 py-1.5 px-2.5 rounded-md text-xs text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] cursor-default transition-all duration-200"
      >
        <div
          class="w-4 h-4 rounded border border-[var(--ap-border)] bg-[var(--ap-bg-base)] flex items-center justify-center transition-all duration-200 aca-check shrink-0"
        >
        </div>
        <span class="flex-1">GPT-4o</span>
      </label>
    </div>
    <button
      id="aca-next3"
      class="w-full py-2 px-3 text-xs font-medium text-stone-50 bg-brand border-none rounded-md cursor-default font-sans transition-all duration-200 mt-1 opacity-50"
      >Review & connect</button
    >
  </div>

  <!-- Screen 4: Confirm summary -->
  <div id="aca-s4" class="hidden flex-col gap-3" data-aca-screen>
    <div
      class="flex items-center gap-2 pb-2.5 border-b border-[var(--ap-border)]"
    >
      <img
        src="/ArlopassIcon.svg"
        alt=""
        width="14"
        height="14"
        aria-hidden="true"
      />
      <span class="text-xs font-semibold text-[var(--ap-text-primary)] flex-1"
        >Confirm connection</span
      >
    </div>
    <div
      class="bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg p-3 flex flex-col gap-2"
    >
      <div class="flex items-center gap-2">
        <div
          class="w-6 h-6 rounded-md bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] flex items-center justify-center shrink-0 overflow-hidden"
        >
          <img
            src="https://excalimate.com/favicon.svg"
            alt=""
            width="14"
            height="14"
            class="w-3.5 h-3.5"
          />
        </div>
        <span class="text-xs font-medium text-[var(--ap-text-primary)]"
          >excalimate.com</span
        >
      </div>
      <div class="border-t border-[var(--ap-border)] pt-2 flex flex-col gap-1">
        <div class="flex justify-between text-[10px]">
          <span class="text-[var(--ap-text-tertiary)]">Providers</span>
          <span class="text-[var(--ap-text-secondary)] font-medium"
            >Claude, OpenAI</span
          >
        </div>
        <div class="flex justify-between text-[10px]">
          <span class="text-[var(--ap-text-tertiary)]">Models</span>
          <span class="text-[var(--ap-text-secondary)] font-medium"
            >Sonnet, GPT-4o</span
          >
        </div>
      </div>
    </div>
    <div class="flex gap-2 mt-1">
      <button
        class="flex-1 py-2 px-3 text-xs font-medium text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-md cursor-default font-sans"
        >Cancel</button
      >
      <button
        id="aca-confirm"
        class="flex-1 py-2 px-3 text-xs font-medium text-stone-50 bg-brand border-none rounded-md cursor-default font-sans transition-all duration-200"
        >Confirm</button
      >
    </div>
  </div>

  <!-- Screen 5: Connecting spinner -->
  <div
    id="aca-spin"
    class="hidden flex-col items-center justify-center gap-3 py-8"
    data-aca-screen
  >
    <div
      class="w-10 h-10 border-2 border-[var(--ap-border)] border-t-brand rounded-full animate-spin"
    >
    </div>
    <p class="text-sm font-medium text-[var(--ap-text-primary)]">Connecting…</p>
    <p class="text-[10px] text-[var(--ap-text-tertiary)]">
      Setting up secure session
    </p>
  </div>

  <!-- Screen 6: Success -->
  <div
    id="aca-ok"
    class="hidden flex-col items-center justify-center gap-2.5 py-6"
    data-aca-screen
  >
    <div
      class="w-11 h-11 rounded-full bg-[var(--ap-success-subtle)] flex items-center justify-center"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--color-success)"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><polyline points="20 6 9 17 4 12"></polyline></svg
      >
    </div>
    <p class="text-sm font-semibold text-[var(--ap-text-primary)]">Connected</p>
    <div
      class="bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-lg p-2.5 w-full"
    >
      <div class="flex flex-col gap-1 text-center">
        <p class="text-[10px] text-[var(--ap-text-tertiary)]">
          excalimate.com can now use
        </p>
        <p class="text-[11px] font-medium text-[var(--ap-text-secondary)]">
          Claude 3.5 Sonnet &middot; GPT-4o
        </p>
      </div>
    </div>
  </div>

  <ClickPing id="aca-cursor" />
</PreviewPanel>

<style>
  .picon {
    filter: brightness(0) invert(0.3);
  }
  .aca-badge-pending {
    color: var(--ap-text-tertiary);
    background: var(--ap-bg-surface);
    border: 1px solid var(--ap-border);
  }
  .aca-checked {
    background: var(--color-brand) !important;
    border-color: var(--color-brand) !important;
  }
  .aca-checked::after {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    background: white;
    border-radius: 1px;
  }
  .aca-row-selected {
    border-color: var(--color-brand) !important;
    background: var(--color-brand-subtle) !important;
    color: var(--color-brand) !important;
  }
</style>

<script>
  function acaRun(p: HTMLElement) {
    const q = (s: string) => p.querySelector(s) as HTMLElement | null;
    const s1 = q("#aca-s1")!,
      s2 = q("#aca-s2")!,
      s3 = q("#aca-s3")!,
      s4 = q("#aca-s4")!;
    const spin = q("#aca-spin")!,
      ok = q("#aca-ok")!;
    const cursor = q("#aca-cursor")!;
    const next1 = q("#aca-next1")!,
      next2 = q("#aca-next2")!,
      next3 = q("#aca-next3")!,
      confirm = q("#aca-confirm")!;
    const p1 = q("#aca-p1")!,
      p2 = q("#aca-p2")!; // Claude + OpenAI
    const m0 = q("#aca-m0")!,
      m1 = q("#aca-m1")!;
    if (!s1) return;

    const tt: number[] = [];
    const t = (fn: () => void, ms: number) =>
      tt.push(window.setTimeout(fn, ms));
    const ping = (el: HTMLElement, dur = 500) =>
      cursor.dispatchEvent(
        new CustomEvent("ping", { detail: { target: el, duration: dur } }),
      );
    const show = (el: HTMLElement) => {
      el.classList.remove("hidden");
      el.classList.add("flex");
    };
    const hide = (el: HTMLElement) => {
      el.classList.add("hidden");
      el.classList.remove("flex");
    };
    const checkRow = (row: HTMLElement) => {
      row.querySelector(".aca-check")?.classList.add("aca-checked");
      row.classList.add("aca-row-selected");
    };

    // Screen 1 visible for ~2.5s, then click Continue
    t(() => {
      ping(next1);
      next1.style.transform = "scale(0.96)";
    }, 2200);
    t(() => {
      next1.style.transform = "scale(1)";
    }, 2400);
    t(() => {
      hide(s1);
      show(s2);
    }, 2700);

    // Screen 2: Select Claude at 3.5s, OpenAI at 4.2s
    t(() => {
      ping(p1);
      checkRow(p1);
    }, 3500);
    t(() => {
      ping(p2);
      checkRow(p2);
    }, 4300);
    // Enable "Next" button
    t(() => {
      next2.style.opacity = "1";
    }, 4600);
    // Click Next at 5.2s
    t(() => {
      ping(next2);
      next2.style.transform = "scale(0.96)";
    }, 5200);
    t(() => {
      next2.style.transform = "scale(1)";
    }, 5400);
    t(() => {
      hide(s2);
      show(s3);
    }, 5700);

    // Screen 3: Select both models at 6.5s and 7.2s
    t(() => {
      ping(m0);
      checkRow(m0);
    }, 6500);
    t(() => {
      ping(m1);
      checkRow(m1);
    }, 7200);
    // Enable "Review" button
    t(() => {
      next3.style.opacity = "1";
    }, 7500);
    // Click Review at 8.2s
    t(() => {
      ping(next3);
      next3.style.transform = "scale(0.96)";
    }, 8200);
    t(() => {
      next3.style.transform = "scale(1)";
    }, 8400);
    t(() => {
      hide(s3);
      show(s4);
    }, 8700);

    // Screen 4: Review summary, click Confirm at 10s
    t(() => {
      ping(confirm);
      confirm.style.transform = "scale(0.96)";
    }, 10000);
    t(() => {
      confirm.style.transform = "scale(1)";
    }, 10200);
    t(() => {
      hide(s4);
      show(spin);
    }, 10500);

    // Screen 5: Spinner for 1.5s
    t(() => {
      hide(spin);
      show(ok);
    }, 12000);

    // Screen 6: Success for 2s, then reset all at once
    t(() => {
      // Hide success and show s1 simultaneously — no empty gap
      hide(ok);
      // Reset checkboxes
      p.querySelectorAll(".aca-check").forEach((c) =>
        c.classList.remove("aca-checked"),
      );
      p.querySelectorAll(".aca-row-selected").forEach((r) =>
        r.classList.remove("aca-row-selected"),
      );
      // Reset buttons
      [next2, next3].forEach((b) => {
        b.style.opacity = "0.5";
        b.style.transform = "scale(1)";
      });
      [next1, confirm].forEach((b) => {
        b.style.transform = "scale(1)";
      });
      // Reset screens
      [s2, s3, s4, spin].forEach(hide);
      show(s1);
      // Signal carousel we're done
      p.dispatchEvent(new CustomEvent("preview:done", { bubbles: false }));
    }, 14200);

    return tt;
  }

  const acaP = document.querySelector(
    "[data-preview]:has(#aca-s1)",
  ) as HTMLElement;
  if (acaP) {
    let at: number[] = [];
    const reset = () => {
      at.forEach(clearTimeout);
      at = [];
      const p = acaP;
      const q = (s: string) => p.querySelector(s) as HTMLElement | null;
      // Reset all screens: hide all, show s1
      ["#aca-s2", "#aca-s3", "#aca-s4", "#aca-spin", "#aca-ok"].forEach((s) => {
        const el = q(s);
        if (el) {
          el.classList.add("hidden");
          el.classList.remove("flex");
        }
      });
      const s1 = q("#aca-s1");
      if (s1) {
        s1.classList.remove("hidden");
        s1.classList.add("flex");
        s1.style.opacity = "1";
      }
      // Reset checks
      p.querySelectorAll(".aca-check").forEach((c) =>
        c.classList.remove("aca-checked"),
      );
      p.querySelectorAll(".aca-row-selected").forEach((r) =>
        r.classList.remove("aca-row-selected"),
      );
      const n2 = q("#aca-next2"),
        n3 = q("#aca-next3");
      if (n2) n2.style.opacity = "0.5";
      if (n3) n3.style.opacity = "0.5";
    };

    const obs = new MutationObserver(() => {
      if (acaP.classList.contains("preview-active")) {
        reset();
        at = acaRun(acaP) || [];
      } else {
        reset();
      }
    });
    obs.observe(acaP, { attributes: true, attributeFilter: ["class"] });

    acaP.addEventListener("preview:loop", () => {
      reset();
      at = acaRun(acaP) || [];
    });
    if (acaP.classList.contains("preview-active")) {
      at = acaRun(acaP) || [];
    }
  }
</script>
