---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Keys never leave your device",
    description:
      "API credentials are stored in your OS keychain — Windows Credential Manager, macOS Keychain, or Linux Secret Service. Not in the browser, not on a server.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: "See every request",
    description:
      "Every AI request passes through your Arlopass. You see exactly what the app is asking, which model will respond, and where data flows.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: "Zero cloud dependency",
    description:
      "Arlopass has no backend, no user accounts, no telemetry. The extension runs locally. Pair it with Ollama for fully offline, zero-exposure AI.",
  },
];
---

<section
  class="py-24 bg-[var(--ap-bg-surface)]"
  id="privacy"
  aria-labelledby="privacy-heading"
>
  <div class="px-4 md:px-6 lg:px-8">
    <div class="text-center max-w-[600px] mx-auto mb-16">
      <span
        class="inline-block text-xs font-medium uppercase tracking-[0.08em] text-brand mb-4"
        >Built for privacy</span
      >
      <h2
        id="privacy-heading"
        class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight mb-4"
      >
        Your keys stay home. Always.
      </h2>
      <p class="text-lg text-[var(--ap-text-secondary)] leading-relaxed">
        No more pasting API keys into apps you don't fully trust. Arlopass keeps
        your credentials in your OS keychain — the app gets AI, you keep
        control.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-16">
      {
        features.map((f) => (
          <div class="p-6 rounded-xl bg-[var(--ap-bg-base)] border border-[var(--ap-border)]">
            <div
              class="flex items-center justify-center w-10 h-10 rounded-lg bg-brand-subtle-dark text-brand mb-4"
              set:html={f.icon}
            />
            <h3 class="text-lg font-semibold mb-2">{f.title}</h3>
            <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
              {f.description}
            </p>
          </div>
        ))
      }
    </div>

    <div
      class="max-w-[700px] mx-auto p-8 bg-[var(--ap-bg-base)] border border-[var(--ap-border)] rounded-lg"
    >
      <div
        class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6"
      >
        <div class="flex flex-col items-center gap-1 p-4 shrink-0">
          <svg
            class="text-[var(--ap-text-tertiary)]"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><circle cx="12" cy="12" r="10"></circle><line
              x1="2"
              y1="12"
              x2="22"
              y2="12"></line><path
              d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
            ></path></svg
          >
          <span class="text-sm font-semibold text-[var(--ap-text-primary)]"
            >Web App</span
          >
        </div>
        <div class="flex flex-col items-center gap-1 shrink-0">
          <span
            class="text-[10px] text-[var(--ap-text-tertiary)] font-mono uppercase tracking-wider"
            >request</span
          >
          <svg
            class="max-md:rotate-90"
            width="40"
            height="12"
            viewBox="0 0 40 12"
            fill="none"
            aria-hidden="true"
            ><line
              x1="0"
              y1="6"
              x2="32"
              y2="6"
              stroke="var(--ap-border-strong)"
              stroke-width="1.5"></line><polyline
              points="30,2 36,6 30,10"
              fill="none"
              stroke="var(--ap-border-strong)"
              stroke-width="1.5"></polyline></svg
          >
        </div>
        <div
          class="flex flex-col items-center gap-1 p-4 px-6 bg-brand-subtle-dark border border-brand/30 rounded-lg shrink-0"
        >
          <img
            src="/ArlopassIcon.svg"
            alt=""
            width="20"
            height="20"
            aria-hidden="true"
          />
          <span class="text-sm font-semibold text-[var(--ap-text-primary)]"
            >Arlopass</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]">You decide</span>
        </div>
        <div class="flex flex-col items-center gap-1 shrink-0">
          <span
            class="text-[10px] text-[var(--ap-text-tertiary)] font-mono uppercase tracking-wider"
            >routed locally</span
          >
          <svg
            class="max-md:rotate-90"
            width="40"
            height="12"
            viewBox="0 0 40 12"
            fill="none"
            aria-hidden="true"
            ><line
              x1="0"
              y1="6"
              x2="32"
              y2="6"
              stroke="var(--color-success)"
              stroke-width="1.5"></line><polyline
              points="30,2 36,6 30,10"
              fill="none"
              stroke="var(--color-success)"
              stroke-width="1.5"></polyline></svg
          >
        </div>
        <div class="flex flex-col items-center gap-1 p-4 shrink-0">
          <svg
            class="text-[var(--ap-text-tertiary)]"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><rect x="4" y="4" width="16" height="16" rx="2"></rect><rect
              x="9"
              y="9"
              width="6"
              height="6"></rect><path
              d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"
            ></path></svg
          >
          <span class="text-sm font-semibold text-[var(--ap-text-primary)]"
            >Your Provider</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]">Your keys</span>
        </div>
      </div>
    </div>
  </div>
</section>
