---
const features = [
  {
    label: "Local storage",
    title: "Keys never leave your device",
    description:
      "API credentials are stored in your OS keychain — Windows Credential Manager, macOS Keychain, or Linux Secret Service. Not in the browser, not on a server.",
  },
  {
    label: "Full visibility",
    title: "See every request",
    description:
      "Every AI request passes through your Arlopass. You see exactly what the app is asking, which model will respond, and where data flows.",
  },
  {
    label: "Zero cloud",
    title: "Zero cloud dependency",
    description:
      "Arlopass has no backend, no user accounts, no telemetry. The extension runs locally. Pair it with Ollama for fully offline, zero-exposure AI.",
  },
];
---

<section class="" id="privacy" aria-labelledby="privacy-heading">
  <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
    <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
      >Built for privacy</span
    >
    <h2
      id="privacy-heading"
      class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
    >
      Your keys stay home. Always.
    </h2>
    <p
      class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
    >
      No more pasting API keys into apps you don't fully trust. Arlopass keeps
      your credentials in your OS keychain — the app gets AI, you keep control.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 border border-[var(--ap-border)]">
    {
      features.map((f, i) => (
        <div
          class={`relative flex flex-col overflow-hidden${i < features.length - 1 ? " border-b md:border-b-0 md:border-r border-[var(--ap-border)]" : ""}`}
        >
          <div class="bg-white hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10 h-full">
            <span class="text-sm font-pixel tracking-[0.08em] text-brand">
              {f.label}
            </span>
            <h3 class="mt-2 text-lg font-semibold tracking-tight text-[var(--ap-text-primary)] mb-2">
              {f.title}
            </h3>
            <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
              {f.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Data flow -->
  <div class="border-x border-b border-[var(--ap-border)] bg-white">
    <div class="py-12 md:py-16 px-6 md:px-10">
      <!-- Flow steps -->
      <div
        class="relative flex flex-col md:flex-row items-center md:items-start justify-center gap-8 md:gap-0 max-w-[580px] mx-auto"
      >
        <!-- Connecting line (desktop only) -->
        <div
          class="hidden md:block absolute top-6 left-[calc(16.67%+12px)] right-[calc(16.67%+12px)] h-px bg-[var(--ap-border)]"
          aria-hidden="true"
        >
        </div>

        <!-- Step 1 -->
        <div
          class="flex-1 flex flex-col items-center text-center relative z-10"
        >
          <div
            class="w-12 h-12 rounded-full bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] flex items-center justify-center mb-3"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--ap-text-secondary)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><line
                x1="2"
                y1="12"
                x2="22"
                y2="12"></line><path
                d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"
              ></path></svg
            >
          </div>
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] mb-0.5"
            >App requests AI</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]">Via the SDK</span
          >
        </div>

        <!-- Chevron (mobile) -->
        <svg
          class="md:hidden w-4 h-4 text-[var(--ap-border-strong)] rotate-90"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >

        <!-- Step 2 -->
        <div
          class="flex-1 flex flex-col items-center text-center relative z-10"
        >
          <div
            class="w-12 h-12 rounded-full bg-brand-subtle border border-brand/25 flex items-center justify-center mb-3"
          >
            <img
              src="/ArlopassIcon.svg"
              alt=""
              width="22"
              height="22"
              aria-hidden="true"
            />
          </div>
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] mb-0.5"
            >You approve</span
          >
          <span class="text-xs text-brand">Choose model &amp; provider</span>
        </div>

        <!-- Chevron (mobile) -->
        <svg
          class="md:hidden w-4 h-4 text-success/60 rotate-90"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >

        <!-- Step 3 -->
        <div
          class="flex-1 flex flex-col items-center text-center relative z-10"
        >
          <div
            class="w-12 h-12 rounded-full bg-[var(--ap-success-subtle)] border border-success/20 flex items-center justify-center mb-3"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="var(--color-success)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polyline points="20 6 9 17 4 12"></polyline></svg
            >
          </div>
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] mb-0.5"
            >Securely routed</span
          >
          <span class="text-xs text-success">Keys never exposed</span>
        </div>
      </div>
    </div>
  </div>
</section>
