---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Keys never leave your device",
    description:
      "API credentials are stored in your OS keychain — Windows Credential Manager, macOS Keychain, or Linux Secret Service. Not in the browser, not on a server.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: "See every request",
    description:
      "Every AI request passes through your Arlopass. You see exactly what the app is asking, which model will respond, and where data flows.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: "Zero cloud dependency",
    description:
      "Arlopass has no backend, no user accounts, no telemetry. The extension runs locally. Pair it with Ollama for fully offline, zero-exposure AI.",
  },
];
---

<section class="privacy" id="privacy" aria-labelledby="privacy-heading">
  <div class="container">
    <div class="privacy-header">
      <span class="section-label">Built for privacy</span>
      <h2 id="privacy-heading" class="section-title">
        Your keys stay home. Always.
      </h2>
      <p class="section-desc">
        No more pasting API keys into apps you don’t fully trust. Arlopass
        keeps your credentials in your OS keychain — the app gets AI, you keep
        control.
      </p>
    </div>

    <div class="privacy-grid">
      {
        features.map((f) => (
          <div class="privacy-card">
            <div class="privacy-icon" set:html={f.icon} />
            <h3 class="privacy-title">{f.title}</h3>
            <p class="privacy-desc">{f.description}</p>
          </div>
        ))
      }
    </div>

    <div class="privacy-visual">
      <div class="data-flow">
        <div class="flow-node flow-app">
          <svg class="flow-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span class="flow-label">Web App</span>
        </div>
        <div class="flow-arrow">
          <span class="flow-arrow-label">request</span>
          <svg
            width="40"
            height="12"
            viewBox="0 0 40 12"
            fill="none"
            aria-hidden="true"
          >
            <line
              x1="0"
              y1="6"
              x2="32"
              y2="6"
              stroke="var(--ap-border-strong)"
              stroke-width="1.5"></line>
            <polyline
              points="30,2 36,6 30,10"
              fill="none"
              stroke="var(--ap-border-strong)"
              stroke-width="1.5"></polyline>
          </svg>
        </div>
        <div class="flow-node flow-arlopass">
          <img
            src="/ArlopassIcon.svg"
            alt=""
            width="20"
            height="20"
            aria-hidden="true"
          />
          <span class="flow-label">Arlopass</span>
          <span class="flow-sub">You decide</span>
        </div>
        <div class="flow-arrow">
          <span class="flow-arrow-label">routed locally</span>
          <svg
            width="40"
            height="12"
            viewBox="0 0 40 12"
            fill="none"
            aria-hidden="true"
          >
            <line
              x1="0"
              y1="6"
              x2="32"
              y2="6"
              stroke="var(--ap-success)"
              stroke-width="1.5"></line>
            <polyline
              points="30,2 36,6 30,10"
              fill="none"
              stroke="var(--ap-success)"
              stroke-width="1.5"></polyline>
          </svg>
        </div>
        <div class="flow-node flow-provider">
          <svg class="flow-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"/></svg>
          <span class="flow-label">Your Provider</span>
          <span class="flow-sub">Your keys</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .privacy {
    padding: var(--ap-space-24) 0;
    border-top: none;
    background: var(--ap-bg-surface);
  }

  .privacy-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--ap-space-16);
  }

  .section-label {
    display: inline-block;
    font-size: var(--ap-text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ap-brand);
    margin-bottom: var(--ap-space-4);
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--ap-space-4);
  }

  .section-desc {
    font-size: var(--ap-text-lg);
    color: var(--ap-text-secondary);
    line-height: 1.6;
  }

  .privacy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--ap-space-6);
    margin-bottom: var(--ap-space-16);
  }

  @media (min-width: 768px) {
    .privacy-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--ap-space-8);
    }
  }

  .privacy-card {
    padding: var(--ap-space-6);
    border-radius: var(--ap-radius-lg);
    background: var(--ap-bg-base);
    border: 1px solid var(--ap-border);
  }

  .privacy-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--ap-radius-md);
    background: var(--ap-brand-subtle-dark);
    color: var(--ap-brand);
    margin-bottom: var(--ap-space-4);
  }

  .privacy-title {
    font-size: var(--ap-text-lg);
    font-weight: 600;
    margin-bottom: var(--ap-space-2);
  }

  .privacy-desc {
    font-size: var(--ap-text-sm);
    color: var(--ap-text-secondary);
    line-height: 1.6;
  }

  /* Data flow diagram */
  .privacy-visual {
    max-width: 700px;
    margin-inline: auto;
    padding: var(--ap-space-8);
    background: var(--ap-bg-base);
    border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius-md);
  }

  .data-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--ap-space-4);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .data-flow {
      flex-wrap: nowrap;
      gap: var(--ap-space-6);
    }
  }

  .flow-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--ap-space-4);
    flex-shrink: 0;
  }

  .flow-icon {
    color: var(--ap-text-tertiary);
  }

  .flow-label {
    font-size: var(--ap-text-sm);
    font-weight: 600;
    color: var(--ap-text-primary);
  }

  .flow-sub {
    font-size: var(--ap-text-xs);
    color: var(--ap-text-tertiary);
  }

  .flow-arlopass {
    background: var(--ap-brand-subtle-dark);
    border: 1px solid color-mix(in oklch, var(--ap-brand) 30%, transparent);
    border-radius: var(--ap-radius-md);
    padding: var(--ap-space-4) var(--ap-space-6);
  }

  .flow-arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .flow-arrow-label {
    font-size: 10px;
    color: var(--ap-text-tertiary);
    font-family: var(--ap-font-code);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
