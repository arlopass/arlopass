---
/**
 * PreviewPanel — A single animated preview slide for use inside PreviewCarousel.
 *
 * Usage:
 *   <PreviewPanel>
 *     <div data-step="0">Step 1 content</div>
 *     <div data-step="1">Step 2 content</div>
 *   </PreviewPanel>
 *
 * Children with [data-step="N"] animate in with staggered delays
 * when this panel becomes active in the carousel.
 *
 * Set loop={8000} to re-trigger the animation every 8s while active.
 */
interface Props {
  class?: string;
  /** If set, re-triggers the slide animation every N ms while it's the active slide */
  loop?: number;
}

const { class: className = "", loop } = Astro.props;
---

<div
  data-preview
  class={className}
  {...loop ? { "data-loop": String(loop) } : {}}
>
  <div
    class="w-[300px] max-[480px]:w-[270px] bg-[var(--ap-bg-base)] border border-[var(--ap-border)] rounded-xl p-5 shadow-[0_8px_32px_rgba(0,0,0,0.1),0_2px_8px_rgba(0,0,0,0.04)] relative overflow-hidden transition-[height] duration-300 ease-out"
    data-preview-card
  >
    <slot />
  </div>
</div>

<script>
  // Auto-resize preview cards to fit their visible content
  document
    .querySelectorAll<HTMLElement>("[data-preview-card]")
    .forEach((card) => {
      const padding = 40; // p-5 = 20px top + 20px bottom

      const resize = () => {
        // Find the visible content child (not click-ping, opacity > 0, not hidden)
        const children = Array.from(card.children) as HTMLElement[];
        const visible = children.find(
          (c) =>
            c.dataset.clickPing === undefined &&
            c.style.opacity !== "0" &&
            c.style.pointerEvents !== "none" &&
            !c.classList.contains("pointer-events-none"),
        );
        if (visible) {
          // Use the visible child's scrollHeight + card padding
          const h = visible.scrollHeight + padding;
          card.style.height = h + "px";
        }
      };

      // Observe style changes on children to detect screen transitions
      const observer = new MutationObserver(resize);
      for (const child of card.children) {
        observer.observe(child, {
          attributes: true,
          attributeFilter: ["style", "class"],
        });
      }

      // Initial size
      resize();
    });
</script>
