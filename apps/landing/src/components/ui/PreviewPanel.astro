---
/**
 * PreviewPanel — A single animated preview slide for use inside PreviewCarousel.
 *
 * Usage:
 *   <PreviewPanel>
 *     <div data-step="0">Step 1 content</div>
 *     <div data-step="1">Step 2 content</div>
 *   </PreviewPanel>
 *
 * Children with [data-step="N"] animate in with staggered delays
 * when this panel becomes active in the carousel.
 *
 * Set loop={8000} to re-trigger the animation every 8s while active.
 */
interface Props {
  class?: string;
  /** If set, re-triggers the slide animation every N ms while it's the active slide */
  loop?: number;
  containerClassName?: string;
}

const { class: className = "", containerClassName = "", loop } = Astro.props;
---

<div
  data-preview
  class={className}
  {...loop ? { "data-loop": String(loop) } : {}}
>
  <div
    class={`w-[300px] max-[480px]:w-[270px] bg-[var(--ap-bg-base)] border border-[var(--ap-border)] rounded-xl p-5 shadow-[0_8px_32px_rgba(0,0,0,0.1),0_2px_8px_rgba(0,0,0,0.04)] relative [interpolate-size:allow-keywords] h-auto transition-[height] duration-250 ease-out ${containerClassName}`}
    data-preview-card
  >
    <slot />
  </div>
</div>
