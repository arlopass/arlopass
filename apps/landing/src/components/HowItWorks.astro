---
import PreviewCarousel from "./ui/PreviewCarousel.astro";
import InstallExtension from "./previews/InstallExtension.astro";
import ConnectProviders from "./previews/ConnectProviders.astro";
import AppConnectionApproval from "./previews/AppConnectionApproval.astro";

const steps = [
  {
    number: "01",
    title: "Install Arlopass",
    description:
      "Add the browser extension from the Chrome Web Store. It takes 30 seconds. No accounts, no cloud, no sign-up.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  },
  {
    number: "02",
    title: "Connect your providers",
    description:
      "Link your AI accounts — Ollama, Claude, GPT, Gemini, Bedrock. Credentials are encrypted in a local vault on your device, never in the browser.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
  },
  {
    number: "03",
    title: "Approve and go",
    description:
      "When a web app wants to use AI, you see exactly what it needs. Pick your model, approve the connection, and it just works from there.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  },
];

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to use Arlopass to manage AI access in web apps",
  description:
    "Set up Arlopass in under a minute to connect your AI providers to any web app without exposing API keys.",
  step: steps.map((s, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: s.title,
    text: s.description,
  })),
  totalTime: "PT1M",
};
---

<section
  class="bg-[var(--ap-bg-surface)]"
  id="how-it-works"
  aria-labelledby="hiw-heading"
>
  <div class="pt-24 px-4 md:px-6 lg:px-8 mb-10 sm:mb-16">
    <span class="block text-sm font-pixel tracking-[0.08em] text-brand"
      >How it works</span
    >
    <h2
      id="hiw-heading"
      class="mt-2 max-w-3xl text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-tight text-balance text-[var(--ap-text-primary)]"
    >
      Up and running in under a minute
    </h2>
    <p
      class="mt-3 max-w-3xl text-base leading-relaxed text-[var(--ap-text-secondary)]"
    >
      No backend to deploy, no accounts to create. Just three quick steps.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 border border-[var(--ap-border)]">
    {
      steps.map((step, i) => (
        <div
          class={`relative flex flex-col overflow-hidden${i < steps.length - 1 ? " border-b md:border-b-0 md:border-r border-[var(--ap-border)]" : ""}`}
        >
          {/* Text section */}
          <div class="bg-[var(--ap-bg-card)] hover:bg-[var(--ap-bg-surface)] transition-colors duration-300 p-8 sm:p-10">
            <span class="text-xs font-semibold text-brand font-mono">
              {step.number}
            </span>
            <h3 class="mt-2 text-xl font-semibold text-[var(--ap-text-primary)] mb-3">
              {step.title}
            </h3>
            <p class="text-sm text-[var(--ap-text-secondary)] leading-relaxed">
              {step.description}
            </p>
          </div>
          {/* Preview section */}
          <div class="relative h-[280px] overflow-hidden border-t border-[var(--ap-border)]">
            <canvas
              data-mosaic-src={`/img/bg${i + 5}.webp`}
              class="absolute inset-0 w-full h-full"
            />
            <div class="absolute inset-0 bg-[var(--ap-mosaic-overlay)]" />
            <div class="relative z-10 h-full pt-5 px-5 bento-glass">
              <div class="h-full -mb-2 rounded-t-xl bg-[var(--ap-glass-bg)] pt-1 px-1 shadow-2xl ring shadow-black/80 ring-[var(--ap-glass-ring)] backdrop-blur-lg overflow-hidden">
                <div class="h-full rounded-t-lg bg-[var(--ap-bg-base)] p-4 overflow-hidden">
                  <PreviewCarousel class="h-full w-full">
                    {i === 0 && <InstallExtension />}
                    {i === 1 && <ConnectProviders />}
                    {i === 2 && <AppConnectionApproval />}
                  </PreviewCarousel>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</section>
