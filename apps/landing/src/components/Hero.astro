---
import PreviewCarousel from "./ui/PreviewCarousel.astro";
import AppConnectionApproval from "./previews/AppConnectionApproval.astro";
import PermissionsManagement from "./previews/PermissionsManagement.astro";
import StreamingChat from "./previews/StreamingChat.astro";
---

<section
  class="relative pt-16 pb-16 overflow-hidden flex items-center lg:pt-24 lg:pb-20"
  aria-labelledby="hero-heading"
>
  <!-- Background panel — right half with mosaic hero image -->
  <div
    class="border-[var(--ap-border)] border-l absolute top-0 bottom-0 right-0 w-full lg:w-1/2 z-0 max-lg:top-auto max-lg:bottom-0 max-lg:h-1/2 overflow-hidden"
    aria-hidden="true"
  >
    <canvas id="hero-mosaic" class="absolute inset-0 w-full h-full"></canvas>
    <div class="absolute inset-0 bg-[var(--ap-mosaic-overlay)]"></div>
  </div>

  <script>
    const TILE = 16;
    const canvas = document.getElementById("hero-mosaic") as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext("2d")!;
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.src = "/img/hero_bg.webp";
      img.onload = () => {
        const draw = () => {
          const w = canvas.clientWidth;
          const h = canvas.clientHeight;
          canvas.width = w;
          canvas.height = h;
          const cols = Math.ceil(w / TILE);
          const rows = Math.ceil(h / TILE);
          // Cover-crop: scale image to fill, center, clip overflow
          const imgRatio = img.naturalWidth / img.naturalHeight;
          const canvasRatio = w / h;
          let sx = 0,
            sy = 0,
            sw = img.naturalWidth,
            sh = img.naturalHeight;
          if (imgRatio > canvasRatio) {
            sw = img.naturalHeight * canvasRatio;
            sx = (img.naturalWidth - sw) / 2;
          } else {
            sh = img.naturalWidth / canvasRatio;
            sy = (img.naturalHeight - sh) / 2;
          }
          const offscreen = document.createElement("canvas");
          offscreen.width = cols;
          offscreen.height = rows;
          const octx = offscreen.getContext("2d")!;
          octx.drawImage(img, sx, sy, sw, sh, 0, 0, cols, rows);
          ctx.imageSmoothingEnabled = false;
          ctx.drawImage(offscreen, 0, 0, cols, rows, 0, 0, w, h);
        };
        draw();
        const ro = new ResizeObserver(draw);
        ro.observe(canvas);
      };
    }
  </script>

  <div
    class="relative z-10 w-full px-4 md:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-10 items-center"
  >
    <!-- Left content -->
    <div
      class="max-w-[540px] max-lg:text-center max-lg:max-w-full max-lg:mx-auto"
    >
      <div
        class="inline-flex items-center gap-2 text-xs font-medium text-[var(--ap-text-secondary)] bg-[var(--ap-bg-surface)] border border-[var(--ap-border)] rounded-full py-1.5 px-3.5 mb-6"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-success shrink-0"></span>
        Free &middot; Open Source &middot; MIT Licensed
      </div>

      <h1
        id="hero-heading"
        class="text-[clamp(2.5rem,5.5vw,3.25rem)] font-[750] leading-[1.08] tracking-[-0.03em] text-[var(--ap-text-primary)] mb-6"
      >
        Your AI, your models,<br />your rules.
      </h1>

      <p
        class="text-base leading-[1.7] text-[var(--ap-text-secondary)] mb-8 max-w-[460px] max-lg:max-w-full max-lg:mx-auto"
      >
        Arlopass is an open-source browser extension that lets web apps use
        <em class="not-italic text-brand">your</em> AI providers — Ollama, Claude,
        GPT, Gemini, or Bedrock — without ever seeing your API keys. You choose which
        apps to trust, pick your model, and stay in control.
      </p>

      <div
        class="flex flex-wrap gap-3 mb-10 max-lg:justify-center max-[480px]:flex-col max-[480px]:items-stretch"
      >
        <a
          href="https://chrome.google.com/webstore"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-cta-text)] bg-[var(--ap-cta-bg)] py-3 px-6 rounded-lg no-underline hover:opacity-85 transition-opacity max-[480px]:justify-center"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line
              x1="12"
              y1="15"
              x2="12"
              y2="3"></line></svg
          >
          Install for Chrome
        </a>
        <a
          href="https://github.com/arlopass"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--ap-text-primary)] bg-transparent border border-[var(--ap-border-strong)] py-3 px-6 rounded-lg no-underline hover:border-[var(--ap-text-tertiary)] hover:bg-[var(--ap-bg-surface)] hover:text-[var(--ap-text-primary)] transition-all max-[480px]:justify-center"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            ><path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          View on GitHub
        </a>
      </div>

      <div class="flex items-center gap-6 flex-wrap max-lg:justify-center">
        <div class="flex flex-col gap-0.5">
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] font-mono"
            >10 lines</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]"
            >to integrate</span
          >
        </div>
        <div class="w-px h-8 bg-[var(--ap-border)]"></div>
        <div class="flex flex-col gap-0.5">
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] font-mono"
            >0 keys</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]"
            >on your server</span
          >
        </div>
        <div class="w-px h-8 bg-[var(--ap-border)]"></div>
        <div class="flex flex-col gap-0.5">
          <span
            class="text-sm font-semibold text-[var(--ap-text-primary)] font-mono"
            >Any model</span
          >
          <span class="text-xs text-[var(--ap-text-tertiary)]"
            >user's choice</span
          >
        </div>
      </div>
    </div>

    <!-- Right visual — Animated preview carousel -->
    <div
      class="flex justify-center items-center min-h-[400px] max-lg:min-h-[320px]"
    >
      <div
        class="transition-all ease-in-out duration-200 rounded-2xl bg-[var(--ap-glass-bg)] p-1 shadow-2xl ring shadow-black/80 ring-[var(--ap-glass-ring)] backdrop-blur-lg"
      >
        <PreviewCarousel
          interval={15000}
          class="w-[300px] max-[480px]:w-[270px] transition-all ease-in-out duration-200"
        >
          <AppConnectionApproval />
          <PermissionsManagement />
          <StreamingChat />
        </PreviewCarousel>
      </div>
    </div>
  </div>
</section>
