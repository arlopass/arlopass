{
  "name": "@arlopass/extension",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Browser extension wallet for consent, provider selection, and secure AI routing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "manifest.json",
    "popup.html",
    "popup.css",
    "options.html"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@arlopass/audit": "workspace:*",
    "@arlopass/policy": "workspace:*",
    "@arlopass/protocol": "workspace:*",
    "@arlopass/web-sdk": "workspace:*",
    "@lobehub/icons-static-svg": "^1.82.0",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^9.0.0",
    "@tabler/icons-react": "^3.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.2.2"
  }
}
