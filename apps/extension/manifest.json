{
  "manifest_version": 3,
  "name": "BYOM AI Wallet",
  "description": "Secure extension surface for BYOM AI provider mediation.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "nativeMessaging"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/provider-injection.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "BYOM AI Wallet",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
