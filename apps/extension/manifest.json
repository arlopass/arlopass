{
  "manifest_version": 3,
  "name": "BYOM AI Wallet",
  "description": "Secure extension surface for BYOM AI provider mediation.",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "nativeMessaging",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http: https:"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "dist/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/inpage-provider.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "action": {
    "default_title": "BYOM AI Wallet",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}