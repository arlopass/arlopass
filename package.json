{
  "name": "arlopass",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Arlopass monorepo workspace bootstrap",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode setup",
    "dev:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode validate",
    "dev:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode watch",
    "dev:bridge": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode bridge",
    "dev:full": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode full",
    "dev:full:tray": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\run-dev.ps1 -Mode full -Tray",
    "dev:register-native-host": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\register-native-host.ps1",
    "dev:e2e-harness": "pnpm --filter @arlopass/e2e-harness dev",
    "build:e2e-harness": "pnpm --filter @arlopass/e2e-harness build",
    "dev:landing": "pnpm --filter @arlopass/landing dev",
    "build:landing": "pnpm -r --filter \"@arlopass/landing...\" --if-present run build",
    "dev:bash:setup": "bash ./scripts/dev/run-dev.sh setup",
    "dev:bash:validate": "bash ./scripts/dev/run-dev.sh validate",
    "dev:bash:watch": "bash ./scripts/dev/run-dev.sh watch",
    "dev:bash:bridge": "bash ./scripts/dev/run-dev.sh bridge",
    "dev:bash:full": "bash ./scripts/dev/run-dev.sh full",
    "install:all": "pnpm install",
    "prepare": "husky",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "vitest --run --passWithNoTests",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:extension": "pnpm exec playwright test --project=extension",
    "test:e2e:webapp": "pnpm exec playwright test --project=webapp",
    "test:e2e:integration": "pnpm exec playwright test --project=integration",
    "test:e2e:cloud": "pnpm exec playwright test --project=extension --grep @cloud-credentials",
    "test:e2e:live": "pnpm exec playwright test --project=live-setup --project=live-providers",
    "test:e2e:report": "pnpm exec playwright show-report e2e/playwright-report"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "eslint --max-warnings=0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.1",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "vite": "^7.3.1"
  }
}
